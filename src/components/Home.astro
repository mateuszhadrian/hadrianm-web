---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/navbar/Navbar.astro";
import Hero from "@/components/sections/hero/Hero.astro";
import HeroBackground from "@/components/sections/hero/HeroBackground.astro";
import Audience from "@/components/sections/audience/Audience.astro";
import AudienceBackground from "@/components/sections/audience/AudienceBackground.astro";
import SectionPlaceholder from "@/components/sections/placeholder/SectionPlaceholder.astro";
import SectionBackground from "@/components/sections/placeholder/SectionBackground.astro";
import LowPowerNotice from "@/components/LowPowerNotice.astro";
import { navItems } from "@/i18n/nav";
import { useTranslations, type Lang } from "@/i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// Sekcje renderowane generycznie jako placeholdery, w kolejności scrolla.
// „Dla kogo" (audience) ma własne, bespoke tło, więc je pomijamy. Nagłówki biorą
// się z navItems (PL/EN); kolory glow z tokenów --sec-* (global.css).
const placeholderIds = navItems
  .map((n) => n.id)
  .filter((id) => id !== "audience");
---

<BaseLayout title={t("meta.title")} lang={lang}>
  <div class="bg-stage" aria-hidden="true">
    <div class="bg-layer" data-bg="hero">
      <HeroBackground />
    </div>
    <div class="bg-layer is-inactive" data-bg="audience">
      <AudienceBackground />
    </div>
    {
      placeholderIds.map((id) => (
        <div
          class="bg-layer is-inactive"
          data-bg={id}
          style={`--g1:var(--sec-${id}-1);--g2:var(--sec-${id}-2)`}
        >
          <SectionBackground />
        </div>
      ))
    }
  </div>

  <Navbar lang={lang} />

  <main class="page">
    <Hero lang={lang} />
    <Audience lang={lang} />
    {placeholderIds.map((id) => <SectionPlaceholder id={id} lang={lang} />)}
  </main>

  <LowPowerNotice lang={lang} />
</BaseLayout>

<style>
  .bg-stage {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: #000; /* widoczne w przerwie między tłami (OVERLAP < 0) */
    pointer-events: none; /* scena nigdy nie przechwytuje klików */
  }
  .bg-layer {
    position: absolute;
    inset: 0;
    opacity: 0;
    will-change: opacity;
  }
  .bg-layer[data-bg="hero"] {
    opacity: 1;
  }
  /* niewidoczna warstwa nie potrzebuje promocji na GPU */
  .bg-layer.is-inactive {
    will-change: auto;
  }

  .page {
    position: relative;
    z-index: 1;
  }

  :global(body) {
    background: #000;
  }
</style>

<script>
  import { initBgCrossfade } from "@/scripts/bg-crossfade";

  // Przenikanie warstw tła (bg-stage) sterowane scrollem — logika w module.
  initBgCrossfade();
</script>
