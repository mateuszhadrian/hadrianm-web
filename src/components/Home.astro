---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/navbar/Navbar.astro";
import Hero from "@/components/sections/hero/Hero.astro";
import HeroBackground from "@/components/sections/hero/HeroBackground.astro";
import Audience from "@/components/sections/audience/Audience.astro";
import AudienceBackground from "@/components/sections/audience/AudienceBackground.astro";
import LowPowerNotice from "@/components/LowPowerNotice.astro";
import { useTranslations, type Lang } from "@/i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<BaseLayout title={t("meta.title")} lang={lang}>
  <div class="bg-stage" aria-hidden="true">
    <div class="bg-layer" data-bg="hero">
      <HeroBackground />
    </div>
    <div class="bg-layer is-inactive" data-bg="audience">
      <AudienceBackground />
    </div>
  </div>

  <Navbar lang={lang} />

  <main class="page">
    <Hero lang={lang} />
    <Audience lang={lang} />
  </main>

  <LowPowerNotice lang={lang} />
</BaseLayout>

<style>
  .bg-stage {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: #000; /* widoczne w przerwie między tłami (OVERLAP < 0) */
    pointer-events: none; /* scena nigdy nie przechwytuje klików */
  }
  .bg-layer {
    position: absolute;
    inset: 0;
    will-change: opacity;
  }
  .bg-layer[data-bg="hero"] {
    opacity: 1;
  }
  .bg-layer[data-bg="audience"] {
    opacity: 0;
  }

  .page {
    position: relative;
    z-index: 1;
  }

  :global(body) {
    background: #000;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const OVERLAP = 0;

  const mm = gsap.matchMedia();

  // — pełna animacja (scrub) —
  mm.add("(prefers-reduced-motion: no-preference)", () => {
    const audience = document.querySelector<HTMLElement>("#audience");
    const heroBg = document.querySelector<HTMLElement>('[data-bg="hero"]');
    const audienceBg = document.querySelector<HTMLElement>(
      '[data-bg="audience"]',
    );
    if (!audience || !heroBg || !audienceBg) return;

    const o = OVERLAP / 2;

    // Pauzuj animacje warstwy, gdy jest praktycznie niewidoczna (oszczędność CPU).
    const syncActive = () => {
      heroBg.classList.toggle(
        "is-inactive",
        parseFloat(getComputedStyle(heroBg).opacity) < 0.01,
      );
      audienceBg.classList.toggle(
        "is-inactive",
        parseFloat(getComputedStyle(audienceBg).opacity) < 0.01,
      );
    };

    const tl = gsap.timeline({
      defaults: { ease: "none" }, // liniowo — postęp 1:1 ze scrollem
      scrollTrigger: {
        trigger: audience, // tło zakotwiczone do sekcji „Dla kogo"
        start: "top bottom", // start, gdy góra sekcji wjeżdża od dołu okna (= koniec hero)
        end: "top top", // koniec, gdy góra sekcji dojedzie do góry okna (≈ 1 ekran przejścia)
        scrub: true,
        onUpdate: syncActive,
      },
    });

    tl.to(heroBg, { opacity: 0, duration: 0.5 + o }, 0).to(
      audienceBg,
      { opacity: 1, duration: 0.5 + o },
      0.5 - o,
    );

    return () => {
      tl.scrollTrigger?.kill();
      tl.kill();
    };
  });

  // — reduced motion: bez przenikania, twardy swap teł na granicy sekcji —
  mm.add("(prefers-reduced-motion: reduce)", () => {
    const audience = document.querySelector<HTMLElement>("#audience");
    const heroBg = document.querySelector<HTMLElement>('[data-bg="hero"]');
    const audienceBg = document.querySelector<HTMLElement>(
      '[data-bg="audience"]',
    );
    if (!audience || !heroBg || !audienceBg) return;

    const st = ScrollTrigger.create({
      trigger: audience,
      start: "top center",
      onToggle: ({ isActive }) => {
        gsap.set(heroBg, { opacity: isActive ? 0 : 1 });
        gsap.set(audienceBg, { opacity: isActive ? 1 : 0 });
        heroBg.classList.toggle("is-inactive", isActive);
        audienceBg.classList.toggle("is-inactive", !isActive);
      },
    });

    return () => st.kill();
  });
</script>
