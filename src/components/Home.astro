---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/navbar/Navbar.astro";
import Hero from "@/components/sections/hero/Hero.astro";
import AmbientBackground from "@/components/backgrounds/AmbientBackground.astro";
import Audience from "@/components/sections/audience/Audience.astro";
import AudienceBackground from "@/components/sections/audience/AudienceBackground.astro";
import Services from "@/components/sections/services/Services.astro";
import ServicesBackground from "@/components/sections/services/ServicesBackground.astro";
import Work from "@/components/sections/work/Work.astro";
import About from "@/components/sections/about/About.astro";
import AboutBackground from "@/components/sections/about/AboutBackground.astro";
import Faq from "@/components/sections/faq/Faq.astro";
import FaqBackground from "@/components/sections/faq/FaqBackground.astro";
import Contact from "@/components/sections/contact/Contact.astro";
import ContactBackground from "@/components/sections/contact/ContactBackground.astro";
import LowPowerNotice from "@/components/LowPowerNotice.astro";
import { useTranslations, type Lang } from "@/i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<BaseLayout title={t("meta.title")} lang={lang}>
  <div class="bg-stage" aria-hidden="true">
    <div class="bg-layer" data-bg="hero">
      <AmbientBackground />
    </div>
    <div class="bg-layer is-inactive" data-bg="audience">
      <AudienceBackground />
    </div>
    <div class="bg-layer is-inactive" data-bg="services">
      <ServicesBackground />
    </div>
    <div class="bg-layer is-inactive" data-bg="work">
      <AmbientBackground />
    </div>
    <div class="bg-layer is-inactive" data-bg="about">
      <AboutBackground />
    </div>
    <div class="bg-layer is-inactive" data-bg="faq">
      <FaqBackground />
    </div>
    <div class="bg-layer is-inactive" data-bg="contact">
      <ContactBackground />
    </div>
  </div>

  <Navbar lang={lang} />

  <main class="page">
    <Hero lang={lang} />
    <Audience lang={lang} />
    <Services lang={lang} />
    <Work lang={lang} />
    <About lang={lang} />
    <Faq lang={lang} />
    <Contact lang={lang} />
  </main>

  <LowPowerNotice lang={lang} />
</BaseLayout>

<style>
  .bg-stage {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: #000; /* widoczne w przerwie między tłami (OVERLAP < 0) */
    pointer-events: none; /* scena nigdy nie przechwytuje klików */
  }
  .bg-layer {
    position: absolute;
    inset: 0;
    opacity: 0;
    will-change: opacity;
  }
  .bg-layer[data-bg="hero"] {
    opacity: 1;
  }
  /* niewidoczna warstwa nie potrzebuje promocji na GPU */
  .bg-layer.is-inactive {
    will-change: auto;
  }

  .page {
    position: relative;
    z-index: 1;
  }

  :global(body) {
    background: #000;
  }
</style>

<script>
  import { initBgCrossfade } from "@/scripts/bg-crossfade";

  // Przenikanie warstw tła (bg-stage) sterowane scrollem — logika w module.
  initBgCrossfade();
</script>
