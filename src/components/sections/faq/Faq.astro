---
import { navItems, navLabel } from "@/i18n/nav";
import type { Lang } from "@/i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const item = navItems.find((n) => n.id === "faq");
const heading = item ? navLabel(item, lang) : "faq";
---

<section id="faq" class="faq">
  <div class="faq__content">
    <h2>{heading}</h2>
  </div>
</section>

<style>
  .faq {
    position: relative;
    min-height: 100svh;
  }

  .faq__content {
    height: 100svh;
    display: grid;
    place-items: center;
    color: #fff;
    font-family: system-ui, sans-serif;
  }

  .faq__content h2 {
    font-size: clamp(1.25rem, 4vw, 2.25rem);
    font-weight: 700;
  }
</style>
