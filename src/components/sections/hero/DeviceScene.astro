---
import LaptopSite from "./LaptopSite.astro";
import PhoneSite from "./PhoneSite.astro";
---

<div class="device-scene">
  <div class="fit">
    <div class="camera" data-gsap="camera">
      <!-- Poświata „podłogi" pod urządzeniami (czerwona mgła) -->
      <div class="device-glow"></div>

      <!-- LAPTOP -->
      <div class="device laptop" data-gsap="laptop">
        <!-- Poświata pod laptopem — tylko mobile (podąża za laptopem) -->
        <div class="device-glow--lap"></div>
        <div class="extrude lid" data-extrude>
          <div class="face">
            <div class="screen screen--laptop" data-gsap="screen-laptop">
              <LaptopSite />
              <!-- Mobile: nagranie animacji laptopa (desktop nie ładuje — preload=none,
                   src wpinany z JS w gałęzi mobile). Poster = pierwsza klatka. -->
              <video
                class="screen__video"
                data-gsap="video-laptop"
                muted
                playsinline
                loop
                preload="none"
                poster="/drewelomet/video/laptop.webp"
                data-src="/drewelomet/video/laptop.mp4"></video>
              <div class="screen__glass"></div>
            </div>
          </div>
        </div>
        <div class="laptop-base" data-gsap="laptop-base">
          <div class="lap-notch"></div>
        </div>
      </div>

      <!-- TELEFON -->
      <div class="device phone" data-gsap="phone">
        <!-- Poświata pod telefonem — tylko mobile (podąża za telefonem) -->
        <div class="device-glow--ph"></div>
        <div class="extrude body" data-extrude>
          <div class="face">
            <div class="screen screen--phone" data-gsap="screen-phone">
              <PhoneSite />
              <!-- Mobile: nagranie animacji telefonu (jak wyżej). -->
              <video
                class="screen__video"
                data-gsap="video-phone"
                muted
                playsinline
                loop
                preload="none"
                poster="/drewelomet/video/phone.webp"
                data-src="/drewelomet/video/phone.mp4"></video>
              <div class="punch"></div>
              <div class="screen__glass"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Tokeny chassis/wymiarów są celowo lokalne dla sceny (specyficzne dla komponentu).
     Token brandowy --glow dziedziczy z :root (global.css). */
  .device-scene {
    --chassis-1: #2b2b30;
    --chassis-2: #161619;
    --chassis-3: #0d0d10;
    --glow-strength: 0.55;
    /* Współczynnik rozmiaru PROJEKTOWEGO sceny. Domyślnie 1; nadpisywany na 0.6
       WYŁĄCZNIE na Androidzie (html.is-android, blok mobile niżej), bo Problem 2
       to limit warstwy GPU Androida. iPhone/iOS NIE jest ruszany — m.in. dlatego,
       że starszy Safari (<16.4, np. iPhone SE 2020 na iOS 15/16) nie wspiera
       @property → tokeny calc(*var(--k)) czytane przez getComputedStyle dawałyby
       NaN i rozwalały geometrię. Patrz docs/naprawa-android-scena-urzadzen-mobile.md. */
    --k: 1;

    /* Tokeny tylko-CSS (rozwiązywane przy użyciu, więc bezpieczne bez @property
       na każdej przeglądarce). Na iPhone --k=1 → wartości identyczne jak dawniej. */
    --lap-w: calc(840px * var(--k));
    --lap-h: calc(534px * var(--k));
    --lap-bezel: calc(11px * var(--k));
    --lap-radius: calc(16px * var(--k));
    --ph-bezel: calc(8px * var(--k));
    --ph-radius: calc(34px * var(--k));

    /* Tokeny czytane z JS (device-scene.ts: dvar → getComputedStyle). GOŁE px po
       to, by działały na Safari bez @property. Na Androidzie blok html.is-android
       niżej nadpisuje --ph-w/--ph-h na calc(*var(--k)) (Chrome wspiera @property).
       --*-depth są czytane TYLKO na desktopie (mobile nie buduje ekstruzji), gdzie
       --k=1, więc zostają gołe i nie wymagają @property. */
    --ph-w: 212px;
    --ph-h: 432px;
    --lap-depth: 16px;
    --ph-depth: 22px;

    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: calc(1900px * var(--k));
    perspective-origin: 50% 44%;
    pointer-events: none;
  }
  .fit {
    --fit: 1; /* skala dopasowania — ustawiana z JS (fit()) */
    position: relative;
    width: calc(1180px * var(--k));
    height: calc(720px * var(--k));
    transform: scale(var(--fit, 1));
    transform-origin: center center;
  }
  .camera {
    /* kąty kamery (--cx/--cy) i wyśrodkowanie grupy (--gx/--gy) — ustawiane z JS */
    --cx: 0deg;
    --cy: 0deg;
    --gx: 0px;
    --gy: 0px;
    position: absolute;
    left: 50%;
    top: 50%;
    transform-style: preserve-3d;
    transform: translate(-50%, -50%) rotateX(var(--cx, 0deg))
      rotateY(var(--cy, 0deg)) translate(var(--gx, 0px), var(--gy, 0px));
    will-change: transform;
  }

  .device {
    position: absolute;
    left: 0;
    top: 0;
    transform-style: preserve-3d;
  }

  /* Poświata „podłogi" pod urządzeniami — eliptyczny, rozmyty radial-gradient
     w kolorze akcentu (jak VenaFloorGlow z k4-ref-C). Wewnątrz .camera, więc
     przesuwa się / skaluje / przechyla razem z grupą (B→C). */
  .device-glow {
    position: absolute;
    left: 0;
    top: 0;
    width: calc(980px * var(--k));
    height: calc(210px * var(--k));
    transform: translate(-50%, -50%)
      translate3d(0, calc(330px * var(--k)), calc(-60px * var(--k)));
    border-radius: 50%;
    background: radial-gradient(
      ellipse at center,
      rgba(var(--glow), 0.34) 0%,
      rgba(0, 0, 0, 0) 65%
    );
    filter: blur(calc(12px * var(--k)));
    pointer-events: none;
  }

  .device-glow--lap,
  .device-glow--ph {
    display: none;
  }

  .extrude {
    /* domyślne; konkretne wartości ustawiają .lid / .body */
    --r: 0px;
    --bezel: 0px;
    position: relative;
    transform-style: preserve-3d;
  }
  .device-scene :global(.extrude__layer) {
    position: absolute;
    inset: 0;
    border-radius: var(--r);
    background: linear-gradient(
      90deg,
      var(--chassis-3) 0%,
      var(--chassis-2) 46%,
      var(--chassis-1) 100%
    );
  }
  .face {
    position: absolute;
    inset: 0;
    border-radius: var(--r);
    padding: var(--bezel);
    box-sizing: border-box;
    background: linear-gradient(
      150deg,
      var(--chassis-1) 0%,
      var(--chassis-2) 60%,
      var(--chassis-3) 100%
    );
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.07),
      0 calc(40px * var(--k)) calc(70px * var(--k)) calc(-34px * var(--k))
        rgba(0, 0, 0, 0.85),
      0 calc(18px * var(--k)) calc(55px * var(--k)) calc(-24px * var(--k))
        rgba(var(--glow), var(--glow-strength));
  }
  .screen {
    width: 100%;
    height: 100%;
    border-radius: calc(var(--r) - var(--bezel) + 2px * var(--k));
    background: #ffffff;
    overflow: hidden;
    position: relative;
  }
  .screen--laptop {
    container-type: size;
  }
  .screen--phone {
    container-type: size;
  }
  .screen__glass {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .screen__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
    background-color: #c9c1b3; /* tło drewelomet — zanim klatka się zdekoduje */
    display: none;
  }

  .laptop {
    /* wjazd na mobile (poziom/głębia) + morph fazy 2 — ustawiane z JS/GSAP */
    --sl-lap: 0px;
    --sz-lap: 0px;
    --apart-lap: 0px; /* rozsunięcie pionowe (mobile: laptop w górę) */
    --lap-yaw: 0deg; /* dodatkowy skręt laptopa na klatce C (desktop) */
    --lap-pitch: 0deg; /* odchylenie pokrywy do tyłu na klatce C (desktop) */
    --vid-scale: 1; /* powiększenie ekranu video (mobile, faza 3) — dół przyklejony */
    transform: translate(-50%, -50%);
  }
  .laptop .lid {
    --r: var(--lap-radius);
    --bezel: var(--lap-bezel);
    width: var(--lap-w);
    height: var(--lap-h);
  }
  .laptop-base {
    position: absolute;
    left: 50%;
    top: calc(var(--lap-h) - 4px * var(--k));
    transform: translateX(-50%);
    width: calc(var(--lap-w) * 1.05);
    height: calc(22px * var(--k));
    border-radius: calc(3px * var(--k)) calc(3px * var(--k))
      calc(17px * var(--k)) calc(17px * var(--k));
    background: linear-gradient(
      180deg,
      var(--chassis-1) 0%,
      var(--chassis-2) 48%,
      var(--chassis-3) 100%
    );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.07),
      0 calc(22px * var(--k)) calc(44px * var(--k)) calc(-22px * var(--k))
        rgba(0, 0, 0, 0.8),
      0 calc(12px * var(--k)) calc(38px * var(--k)) calc(-18px * var(--k))
        rgba(var(--glow), var(--glow-strength));
  }
  .lap-notch {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 14%;
    height: calc(7px * var(--k));
    background: rgba(0, 0, 0, 0.45);
    border-radius: 0 0 calc(10px * var(--k)) calc(10px * var(--k));
  }

  .phone {
    /* wjazd na mobile (poziom/głębia) + morph fazy 2 — ustawiane z JS/GSAP */
    --sl-ph: 0px;
    --sz-ph: 0px;
    --apart-ph: 0px; /* rozsunięcie pionowe (mobile: telefon w dół) */
    --ph-dx: 0px; /* przejazd prawo→lewo na klatce C (desktop) */
    --ph-dy: 0px;
    --ph-dz: 0px; /* wysunięcie do przodu na klatce C (desktop) */
    --vid-scale: 1; /* powiększenie ekranu video (mobile, faza 3) — dół przyklejony */
    transform: translate(-50%, -50%);
    will-change: transform;
  }
  .phone .body {
    --r: var(--ph-radius);
    --bezel: var(--ph-bezel);
    width: var(--ph-w);
    height: var(--ph-h);
  }
  .punch {
    position: absolute;
    top: calc(11px * var(--k));
    left: 50%;
    transform: translateX(-50%);
    width: calc(11px * var(--k));
    height: calc(11px * var(--k));
    border-radius: 99px;
    background: #0a0a0a;
    box-shadow: inset 0 0 0 calc(2px * var(--k)) rgba(255, 255, 255, 0.06);
    z-index: 2;
  }

  /* ── mobile: większy bazowy telefon (bez scale — treść na ekranie zostaje ostra,
        a w kolejnym etapie ekrany będą rosły wraz ze scrollowaną treścią) ── */
  @media (max-width: 760px) {
    .screen__video {
      display: block;
    }
    .device-scene {
      /* Bazowy telefon mobile. --ph-w/--ph-h GOŁE px (czytane z JS; działa bez
         @property, np. iPhone SE 2020 / starszy Safari). --ph-radius/--ph-bezel
         to tokeny tylko-CSS → mogą zostać calc(*var(--k)); na iPhone --k=1 daje
         oryginał, na Androidzie skalują się razem z resztą. */
      --ph-w: 286px;
      --ph-h: 584px;
      --ph-radius: calc(46px * var(--k));
      --ph-bezel: calc(11px * var(--k));
      perspective: none;
    }
    /* ── ANDROID ONLY (Problem 2): zmniejsz rozmiar PROJEKTOWY sceny — fit()
       kompensuje ×1/--k, więc wygląd identyczny, a rasteryzowana warstwa jest
       ~K× mniejsza (zapas pod limitem tekstury GPU). Klasę is-android ustawia
       Hero.astro PRZED initDeviceScene, więc dvar czyta już skalowane --ph-w/--ph-h
       (Chrome wspiera @property). iPhone/iOS nie wchodzi tu nigdy. */
    html.is-android .device-scene {
      --k: 0.6;
      --ph-w: calc(286px * var(--k));
      --ph-h: calc(584px * var(--k));
    }
    .camera,
    .device,
    .extrude {
      transform-style: flat;
    }
    .camera,
    .phone {
      will-change: auto;
    }
    .camera {
      --cx: 4deg;
    }
    .face {
      box-shadow:
        inset 0 0 0 1px rgba(255, 255, 255, 0.06),
        0 calc(12px * var(--k)) calc(30px * var(--k)) calc(-18px * var(--k))
          rgba(0, 0, 0, 0.7);
    }
    .laptop-base {
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }
    .device-glow {
      display: none;
    }
    .device-glow--lap,
    .device-glow--ph {
      display: block;
      position: absolute;
      left: 50%;
      top: 100%;
      border-radius: 50%;
      /* płasko (bez translateZ — scena nie ma perspektywy); miękkie krawędzie
         daje sam radial-gradient, więc filter: blur jest zbędny i kosztowny */
      transform: translate(-50%, -45%);
      background: radial-gradient(
        ellipse at center,
        rgba(var(--glow), 0.32) 0%,
        rgba(0, 0, 0, 0) 68%
      );
      pointer-events: none;
    }
    .device-glow--lap {
      width: calc(var(--lap-w) * 1.15);
      height: calc(230px * var(--k));
    }
    .device-glow--ph {
      width: calc(var(--ph-w) * 1.5);
      height: calc(var(--ph-w) * 0.42);
    }
  }
</style>

<!-- Rejestracja tokenów, które na ANDROIDZIE stają się calc(*var(--k)) a są czytane
     przez device-scene.ts (dvar → getComputedStyle + parseFloat). Bez @property
     niezarejestrowana custom property zwraca nierozwiązany string ("calc(286px *
     var(--k))") → parseFloat=NaN. @property z syntax:<length> wymusza obliczoną
     długość. Tylko --ph-w/--ph-h, bo tylko one są skalowane (czytane na mobile);
     --*-depth zostają gołe (czytane wyłącznie na desktopie, --k=1). Wspierane na
     Androidzie (Chrome≥85); iPhone używa gołych px, więc @property tam nie jest
     potrzebne. (at-rule globalna → is:global.) -->
<style is:global>
  @property --ph-w {
    syntax: "<length>";
    inherits: true;
    initial-value: 0px;
  }
  @property --ph-h {
    syntax: "<length>";
    inherits: true;
    initial-value: 0px;
  }
</style>
