---
import { useTranslations, type Lang } from "@/i18n/utils";
import DeviceScene from "./DeviceScene.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const accentLetters = [...t("hero.headlineAccent")];
const accentN = accentLetters.length;
---

<section id="hero" class="hero">
  <div class="hero__stage">
    <div class="hero__head">
      <p class="hero__eyebrow">{t("hero.eyebrow")}</p>
      <h1 class="hero__headline">
        {t("hero.headlineLead")}{" "}
        <span class="hero__accent hero__accent--ghost" style={`--n:${accentN}`}>
          {
            accentLetters.map((ch, i) => (
              <span class="hero__accent-ltr" style={`--i:${i}`}>
                {ch}
              </span>
            ))
          }
        </span>
      </h1>

      <div class="hero__scroll">
        <span class="hero__scroll-label">{t("hero.scroll")}</span>
        <span class="hero__scroll-line" aria-hidden="true"></span>
      </div>
    </div>

    <!-- Animowana kopia słowa "inna": nakładana JS-em na ghost, jedzie do środka
         viewportu, skaluje się ku użytkownikowi i rozmywa. aria-hidden, bo treść
         niesie ghost w <h1> powyżej. -->
    <span
      class="hero__accent hero__accent--live"
      aria-hidden="true"
      style={`--n:${accentN}`}
    >
      {
        accentLetters.map((ch, i) => (
          <span class="hero__accent-ltr" style={`--i:${i}`}>
            {ch}
          </span>
        ))
      }
    </span>

    <!-- Tekst (placeholder) — faza 2. Desktop: lewa kolumna; mobile: 3 pasma
         interleaved z urządzeniami (dividery nad 02 i 03). Pojawia się przy
         przesuwaniu urządzeń w prawo (desktop) / rozsuwaniu (mobile). -->
    <div class="hero__copy">
      <div class="hero__copy-row hero__copy-row--1">
        <span class="hero__copy-num">01</span>
        <p class="hero__copy-text">
          {t("hero.s1Lead")}
          <em>{t("hero.s1Accent")}</em>
        </p>
      </div>
      <div class="hero__copy-row hero__copy-row--2">
        <span class="hero__copy-num">02</span>
        <p class="hero__copy-text">{t("hero.s2")}</p>
      </div>
      <div class="hero__copy-row hero__copy-row--3">
        <span class="hero__copy-num">03</span>
        <p class="hero__copy-text">{t("hero.s3")}</p>
      </div>
    </div>

    <!-- Scena urządzeń (laptop + smartfon). Wrapper .hero__devices to „slot" w
         stage'u: pozycjonowany i animowany przez timeline (opacity/blur/scale/x).
         Wnętrze sceny + jej logika żyją w DeviceScene.astro / device-scene.ts. -->
    <div class="hero__devices" aria-hidden="true">
      <DeviceScene />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;

    /* tokeny brandowe (--ink/--muted/--faint/--line/--accent/--glow) dziedziczą z :root */
    --headline-size: clamp(2.75rem, 7.9vw, 9.4rem);
  }

  .hero__stage {
    position: relative;
  }

  .hero__head {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(1.5rem, 2.1vw, 2.5rem);
    padding: 0 clamp(1.5rem, 9.4vw, 11.25rem);
    text-align: center;
  }

  .hero__eyebrow {
    margin: 0;
    font-family: var(--font-mono), monospace;
    font-size: clamp(0.62rem, 0.66vw, 0.75rem);
    letter-spacing: 0.44em;
    text-indent: 0.44em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .hero__headline {
    margin: 0;
    max-width: 18ch;
    font-family: var(--font-display), sans-serif;
    font-weight: 800;
    font-size: var(--headline-size);
    line-height: 1.04;
    letter-spacing: -0.035em;
    color: var(--ink);
    text-wrap: balance;
  }

  .hero__accent {
    --n: 1;
    font-family: var(--font-serif), serif;
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0;
    white-space: nowrap;
  }
  /* Ghost: rozmiar względem <h1>; live: ten sam rozmiar liczony bezpośrednio. */
  .hero__headline .hero__accent {
    font-size: 1.06em;
  }
  .hero__accent--live {
    display: none;
    font-size: calc(var(--headline-size) * 1.06);
  }

  .hero__accent-ltr {
    --i: 0;
    display: inline-block;
    padding: 0.3em 0.36em;
    margin: -0.3em -0.36em;
    background: var(--accent-gradient)
      calc(var(--i) / max(var(--n) - 1, 1) * 100%) 50% / calc(var(--n) * 100%)
      100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    animation: accent-wave 2.4s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.08s);
    will-change: transform;
  }
  .hero__accent--live.is-wave-paused .hero__accent-ltr {
    animation-play-state: paused;
  }

  .hero__scroll {
    position: absolute;
    bottom: clamp(1.25rem, 4vh, 2.75rem);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .hero__scroll-label {
    font-family: var(--font-mono), monospace;
    font-size: clamp(0.6rem, 0.6vw, 0.7rem);
    letter-spacing: 0.34em;
    text-indent: 0.34em;
    color: var(--faint);
  }
  .hero__scroll-line {
    width: 1px;
    height: clamp(2rem, 4.25vh, 2.875rem);
    background: linear-gradient(
      180deg,
      var(--accent) 0%,
      rgba(0, 0, 0, 0) 100%
    );
    transform-origin: top;
    animation: scroll-pulse 2.4s ease-in-out infinite;
  }

  /* ─────────────────────────── TEKST (placeholder) ─────────────────────────
     Bazowo: zwykły blok w przepływie (fallback reduced-motion / brak JS).
     W trybie ruchu (no-preference) pozycjonowany absolutnie i odsłaniany GSAP-em. */
  .hero__copy {
    max-width: 40rem;
    margin: 0 auto;
    padding: clamp(2rem, 7vw, 5rem);
    display: flex;
    flex-direction: column;
  }
  .hero__copy-row {
    display: flex;
    gap: clamp(0.85rem, 1.4vw, 1.4rem);
    align-items: baseline;
  }
  .hero__copy-row--2,
  .hero__copy-row--3 {
    border-top: 1px solid var(--line);
    margin-top: clamp(1.1rem, 2vw, 1.65rem);
    padding-top: clamp(1.1rem, 2vw, 1.65rem);
  }
  .hero__copy-num {
    flex-shrink: 0;
    font-family: var(--font-mono), monospace;
    font-size: clamp(0.7rem, 0.8vw, 0.82rem);
    color: var(--accent);
  }
  .hero__copy-text {
    margin: 0;
    color: var(--muted);
    font-family: var(--font-display), sans-serif;
    font-weight: 600;
    font-size: clamp(1rem, 1.45vw, 1.65rem);
    line-height: 1.3;
    text-wrap: balance;
  }
  .hero__copy-row--1 .hero__copy-text {
    color: var(--ink);
    font-weight: 800;
    font-size: clamp(2rem, 3.9vw, 3.75rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }
  .hero__copy-text em {
    font-family: var(--font-serif), serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1.06em;
    letter-spacing: 0;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  /* ─────────────────────────── SCENA URZĄDZEŃ (slot) ───────────────────────
     Wrapper sceny — pozycja w przepływie + animacja przez timeline. Wnętrze
     sceny (3D, tokeny chassis/wymiary) jest w DeviceScene.astro. */
  .hero__devices {
    position: relative;
    min-height: 100svh;
  }

  /* ───────────────── TRYB ANIMACJI (ruch dozwolony) ─────────────────
     Stage przykleja się (sticky), a head + urządzenia leżą na sobie w
     centrum — różnicę robi timeline GSAP. ── */
  @media (prefers-reduced-motion: no-preference) {
    .hero {
      /* faza 1 (~1,4 ekr.) + faza 2 (~2,2 ekr.) napędzane scrollem (end +=4×vh)
         + ~2 ekrany holdu, zanim sekcja się odpina (mobile — bez fazy 3) */
      min-height: 700svh;
    }
    .hero__stage {
      position: sticky;
      top: 0;
      height: 100svh;
      overflow: clip;
    }
    .hero__head {
      position: absolute;
      inset: 0;
      min-height: auto;
      will-change: transform;
    }
    .hero__devices {
      position: absolute;
      inset: 0;
      min-height: auto;
      opacity: 0;
      will-change: transform, opacity;
    }
    .hero__accent--live {
      display: block;
      /* absolute względem przyklejonego stage'u (nie fixed — fixed dryfuje na
         mobile przy chowaniu paska adresu) */
      position: absolute;
      left: 0;
      top: 0;
      opacity: 0;
      z-index: 5;
      transform-origin: 50% 50%;
      pointer-events: none;
      will-change: transform, opacity;
    }

    /* ── DESKTOP/TABLET: lewa kolumna, wyśrodkowana w pionie, odsłaniana GSAP-em.
       Odstęp tekst↔urządzenia steruje `left` + `width` (clamp → nigdy zerowy). ── */
    .hero__copy {
      position: absolute;
      top: 50%;
      left: clamp(2.5rem, 7.5vw, 9.5rem);
      transform: translateY(-50%);
      width: clamp(18rem, 31vw, 31rem);
      max-width: none;
      margin: 0;
      padding: 0;
      opacity: 0;
      z-index: 4;
      pointer-events: none;
      will-change: transform, opacity;
    }
  }

  /* ── MOBILE w trybie ruchu: 3 pasma interleaved z urządzeniami.
     Pozycje pasm (top) dobrane wstępnie — do doszlifowania wizualnie. ── */
  @media (prefers-reduced-motion: no-preference) and (max-width: 760px) {
    .hero__copy {
      position: absolute;
      inset: 0;
      width: auto;
      left: 0;
      top: 0;
      transform: none;
      padding: 0;
      opacity: 0;
      z-index: 4;
      pointer-events: none;
      will-change: opacity;
    }
    .hero__copy-row {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      width: min(86vw, 26rem);
      margin: 0;
    }
    .hero__copy-row--1 {
      top: 7svh;
    }
    .hero__copy-row--2 {
      top: 45svh;
    }
    .hero__copy-row--3 {
      top: 82svh;
    }
  }

  /* Desktop/tablet: dodatkowy dystans na FAZĘ 3 (strona drewelomet na laptopie).
     Start fazy 3 nakłada się na morf (klatka C), więc cała oś = ~12 ekranów
     scrubu + ~2 ekrany holdu przed odpięciem. */
  @media (prefers-reduced-motion: no-preference) and (min-width: 761px) {
    .hero {
      min-height: 1400svh;
    }
  }

  @keyframes scroll-pulse {
    0%,
    100% {
      opacity: 0.55;
      transform: scaleY(0.82);
    }
    50% {
      opacity: 1;
      transform: scaleY(1);
    }
  }

  @keyframes accent-wave {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-0.12em);
    }
  }

  /* ── niski ekran (telefon w poziomie / krótkie okno) */
  @media (max-height: 600px) {
    .hero__eyebrow,
    .hero__scroll-label {
      display: none;
    }
    .hero {
      --headline-size: clamp(2.25rem, 6.4vw, 7.5rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-line,
    .hero__accent-ltr {
      animation: none;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { initDeviceScene, FRAME_C } from "./device-scene";
  import { initLaptopSite, type LaptopSiteApi } from "./laptop-site";
  import { initPhoneSite, type PhoneSiteApi } from "./phone-site";

  gsap.registerPlugin(ScrollTrigger);

  ScrollTrigger.config({ ignoreMobileResize: true });
  ScrollTrigger.normalizeScroll(true);

  // ── Scena urządzeń: budowa brył 3D, geometria klatki B, fit do viewportu i
  //    adaptacyjna klatka C — całość w device-scene.ts. Timeline poniżej tylko
  //    animuje zmienne CSS sceny i czyta `scene.getFrameC()` (klatka C). ──
  const devicesEl = document.querySelector<HTMLElement>(".hero__devices");
  const scene = devicesEl ? initDeviceScene(devicesEl) : null;

  /* ── Animacja sterowana scrollem (tylko gdy ruch dozwolony) ── */
  const mm = gsap.matchMedia();

  const q = <T extends HTMLElement = HTMLElement>(s: string) =>
    document.querySelector<T>(s);

  // Wspólny szkielet: refy, pomiary, oś czasu + części niezależne od wariantu.
  // `screens` = ile ekranów scrolla obejmuje cała oś timeline (desktop dłuższy
  // o fazę 3 = strona drewelomet na laptopie).
  const buildBase = (screens: number) => {
    const hero = q("#hero");
    const stage = q(".hero__stage");
    const head = q(".hero__head");
    const ghost = q(".hero__accent--ghost");
    const live = q(".hero__accent--live");
    const devices = q(".hero__devices");
    const copy = q(".hero__copy");
    const scroll = q(".hero__scroll");
    if (!hero || !stage || !head || !ghost || !live || !devices) return null;

    // Pozycja słowa mierzona WZGLĘDEM .hero__head — różnica ghost−head kasuje
    // przesunięcie głowy, pozycję viewportu i chowający się pasek adresu (brak przeskoków).
    const rect = () => {
      const g = ghost.getBoundingClientRect();
      const h = head.getBoundingClientRect();
      return {
        left: g.left - h.left,
        top: g.top - h.top,
        width: g.width,
        height: g.height,
      };
    };
    const startX = () => rect().left;
    const startY = () => rect().top;
    const endX = () => stage.clientWidth / 2 - rect().width / 2;
    const endY = () => stage.clientHeight / 2 - rect().height / 2;

    // ghost znika wizualnie, ale zostaje w drzewie dostępności (opacity, nie visibility)
    gsap.set(ghost, { opacity: 0 });

    const tl = gsap.timeline({
      defaults: { ease: "none" },
      scrollTrigger: {
        trigger: hero,
        start: "top top",
        // faza 1 (przelot słowa + urządzenia na środku) + faza 2 (morph 3D /
        // rozsunięcie + tekst) napędzane scrollem przez ~4 ekrany; potem ~2 ekrany
        // holdu (z min-height: 700svh), zanim sekcja się odpina
        end: () => "+=" + window.innerHeight * screens,
        scrub: true,
        invalidateOnRefresh: true,
        onUpdate: (self) =>
          live.classList.toggle("is-wave-paused", self.progress > 0.3),
      },
    });

    // część nieanimowana odjeżdża w górę (≈ tempo scrolla)
    tl.to(head, { yPercent: -110, duration: 0.6 }, 0);
    if (scroll) tl.to(scroll, { autoAlpha: 0, duration: 0.12 }, 0);

    return {
      tl,
      ghost,
      live,
      devices,
      copy,
      scroll,
      startX,
      startY,
      endX,
      endY,
    };
  };

  type Base = NonNullable<ReturnType<typeof buildBase>>;
  // Refy urządzeń sceny — wspólne dla obu wariantów (selektory = kontrakt z DeviceScene).
  type DeviceRefs = {
    laptop: HTMLElement | null;
    phone: HTMLElement | null;
    camera: HTMLElement | null;
    base: HTMLElement | null;
  };
  const deviceRefs = (): DeviceRefs => ({
    laptop: q("[data-gsap='laptop']"),
    phone: q("[data-gsap='phone']"),
    camera: q(".hero__devices .camera"),
    base: q("[data-gsap='laptop-base']"),
  });

  const cleanup = (b: Base) => () => {
    b.tl.scrollTrigger?.kill();
    b.tl.kill();
    gsap.set([b.ghost, b.live, b.devices, b.copy, b.scroll].filter(Boolean), {
      clearProps: "all",
    });
    // zdejmij morph z urządzeń (zmienne CSS) + przywróć pasek bazy
    const { laptop: lp, phone: ph, camera: cam, base: bs } = deviceRefs();
    lp?.style.removeProperty("--lap-yaw");
    lp?.style.removeProperty("--lap-pitch");
    lp?.style.removeProperty("--apart-lap");
    ph?.style.removeProperty("--ph-dx");
    ph?.style.removeProperty("--ph-dy");
    ph?.style.removeProperty("--ph-dz");
    ph?.style.removeProperty("--apart-ph");
    cam?.style.removeProperty("--cx");
    cam?.style.removeProperty("--cy");
    if (bs) gsap.set(bs, { clearProps: "opacity" });
  };

  // ════════════════════════════ FAZY (desktop) ════════════════════════════

  // FAZA 1: słowo "inna" jedzie do środka viewportu, skaluje się ku użytkownikowi
  // i rozmywa → zanik; urządzenia wyostrzają się z rozmycia w centrum.
  const phase1Desktop = (b: Base) => {
    const { tl, live, devices, startX, startY, endX, endY } = b;
    tl.fromTo(
      live,
      { x: startX, y: startY, scale: 1, filter: "blur(0px)", autoAlpha: 1 },
      {
        x: endX,
        y: endY,
        scale: 5.2,
        filter: "blur(24px)",
        duration: 0.5,
        ease: "power1.in",
      },
      0.15,
    );
    tl.to(live, { autoAlpha: 0, duration: 0.13 }, 0.56);

    // urządzenia: rozmyte chwilę przed zanikiem słowa → wyostrzenie w centrum
    tl.fromTo(
      devices,
      { autoAlpha: 0, filter: "blur(26px)", scale: 1.22 },
      {
        autoAlpha: 1,
        filter: "blur(0px)",
        scale: 1,
        duration: 0.38,
        ease: "power2.out",
      },
      0.5,
    );
  };

  // FAZA 2 (desktop): morph 3D wg produkcja.html + przesuw grupy w prawo + wjazd
  // tekstu z lewej. Wszystko równolegle, napędzane scrollem.
  const phase2Desktop = (b: Base, refs: DeviceRefs) => {
    const { tl, copy, devices } = b;
    const { laptop, phone, camera, base } = refs;
    const PH2 = 0.95; // start fazy 2 na osi timeline (po wejściu urządzeń)
    // Pozycja/skala grupy w klatce C są adaptacyjne (scene.getFrameC(), liczone
    // w layout): grupa dopasowuje się do prawej strefy — może rosnąć lub maleć.

    // (a) telefon: przejazd prawo→lewo + wysunięcie do przodu + niżej (klatka B→C)
    if (phone) {
      tl.to(
        phone,
        {
          "--ph-dx": FRAME_C.phDx + "px",
          "--ph-dy": FRAME_C.phDy + "px",
          "--ph-dz": FRAME_C.phDz + "px",
          duration: 0.5,
          ease: "power2.inOut",
        },
        PH2,
      );
    }
    // (b) zanik paska bazy laptopa (klawiatury) — gdy laptop staje pod kątem,
    //     pasek nie może być widoczny
    if (base) {
      tl.to(
        base,
        { autoAlpha: 0, duration: 0.4, ease: "power2.inOut" },
        PH2 + 0.03,
      );
    }
    // (c) ruch kamery B→C + skręt (yaw) i odchylenie do tyłu (pitch) laptopa
    if (camera) {
      tl.to(
        camera,
        {
          "--cx": FRAME_C.camCx + "deg",
          "--cy": FRAME_C.camCy + "deg",
          duration: 0.5,
          ease: "power2.inOut",
        },
        PH2 + 0.45,
      );
    }
    if (laptop) {
      tl.to(
        laptop,
        {
          "--lap-yaw": FRAME_C.lapYaw + "deg",
          "--lap-pitch": FRAME_C.lapPitch + "deg",
          duration: 0.5,
          ease: "power2.inOut",
        },
        PH2 + 0.45,
      );
    }
    // (d) cała grupa dopasowuje się do prawej strefy (adaptacyjnie: rośnie lub
    //     maleje) i jedzie w prawo, robiąc miejsce na tekst z lewej
    tl.to(
      devices,
      {
        x: () => scene?.getFrameC().x ?? 0,
        scale: () => scene?.getFrameC().scale ?? 1,
        transformOrigin: "50% 50%",
        duration: 1.0,
        ease: "power2.inOut",
      },
      PH2,
    );
    // (e) tekst po lewej: fade + slide od lewej (kończy razem z dojściem do C)
    if (copy) {
      tl.fromTo(
        copy,
        { autoAlpha: 0, x: -48 },
        { autoAlpha: 1, x: 0, duration: 0.6, ease: "power2.out" },
        PH2 + 0.35,
      );
    }
  };

  // FAZA 3 (desktop): laptop stoi w klatce C (bez ruchu), a dalszy scroll napędza
  // master-timeline strony drewelomet na jego ekranie (sprzężenie 1:1). Po dojściu
  // do progress=1 dalszy scroll wynosi sekcję (handoff do Problem w Home.astro).
  const phase3Desktop = (b: Base, site: LaptopSiteApi) => {
    const { tl } = b;
    // Start od pojawienia się urządzeń w centrum (urządzenia ostre ~0.88, morf
    // PH2=0.95) — animacja ekranu biegnie DALEJ równolegle z morfem do klatki C.
    const PH3_START = 0.9;
    const DREWELOMET_DUR = 5.0; // przy buildBase(12) ≈ 10 ekranów scrolla
    const p = { v: 0 };
    tl.to(
      p,
      {
        v: 1,
        ease: "none",
        duration: DREWELOMET_DUR,
        onUpdate: () => site.master.progress(p.v),
        onStart: () => site.setActive(true),
        onComplete: () => site.setActive(false),
        onReverseComplete: () => site.setActive(false),
      },
      PH3_START,
    );
  };

  const phase3PhoneDesktop = (b: Base, phone: PhoneSiteApi) => {
    const { tl } = b;
    const PHONE_START = 2.0;
    const PHONE_END = 5.9;
    const p = { v: 0 };
    tl.to(
      p,
      {
        v: 1,
        ease: "none",
        duration: PHONE_END - PHONE_START,
        onUpdate: () => phone.master.progress(p.v),
        onStart: () => phone.setActive(true),
        onComplete: () => phone.setActive(false),
        onReverseComplete: () => phone.setActive(false),
      },
      PHONE_START,
    );
  };

  // ════════════════════════════ FAZY (mobile) ═════════════════════════════

  // FAZA 1 (mobile): ZERO blura. Słowo gaśnie samym opacity; urządzenia widoczne
  // i ostre wjeżdżają ŁUKIEM w płaszczyźnie XZ (laptop z prawej+tyłu, telefon z
  // lewej+przodu). Różne ease na X i Z wyginają tor. Wszystko to sam transform.
  const phase1Mobile = (
    b: Base,
    refs: DeviceRefs,
    slide: () => number,
    zDepth: () => number,
  ) => {
    const { tl, live, devices, startX, startY } = b;
    const { laptop, phone } = refs;

    // słowo: hold w miejscu, potem sam zanik (bez skali/blura/przejazdu)
    tl.fromTo(
      live,
      { x: startX, y: startY, scale: 1, autoAlpha: 1 },
      { autoAlpha: 0, duration: 0.17 },
      0.45,
    );

    gsap.set(devices, { autoAlpha: 1, filter: "none", scale: 1 });
    if (laptop) {
      tl.fromTo(
        laptop,
        { "--sl-lap": () => slide() + "px" },
        { "--sl-lap": "0px", duration: 0.7, ease: "power4.out" },
        0.5,
      );
      tl.fromTo(
        laptop,
        { "--sz-lap": () => -zDepth() + "px" },
        { "--sz-lap": "0px", duration: 0.7, ease: "power2.out" },
        0.5,
      );
    }
    if (phone) {
      tl.fromTo(
        phone,
        { "--sl-ph": () => -slide() + "px" },
        { "--sl-ph": "0px", duration: 0.7, ease: "power4.out" },
        0.5,
      );
      tl.fromTo(
        phone,
        { "--sz-ph": () => zDepth() + "px" },
        { "--sz-ph": "0px", duration: 0.7, ease: "power2.out" },
        0.5,
      );
    }
  };

  // FAZA 2 (mobile): urządzenia rozsuwają się (laptop↑, telefon↓) i grupa
  // pomniejsza się, robiąc miejsce na dividery + tekst (01 góra, 02 między,
  // 03 pod telefonem). Tekst pojawia się równolegle.
  const phase2Mobile = (b: Base, refs: DeviceRefs) => {
    const { tl, copy, devices } = b;
    const { laptop, phone } = refs;
    const APART_START = 1.3; // start rozsunięcia (po zakończeniu wjazdu)
    const APART_LAP = -150; // laptop w górę (px projektu)
    const APART_PH = 170; // telefon w dół (px projektu)
    const MOB_END_SCALE = 0.82; // pomniejszenie grupy (miejsce na tekst góra/dół)

    if (laptop) {
      tl.to(
        laptop,
        {
          "--apart-lap": APART_LAP + "px",
          duration: 0.6,
          ease: "power2.inOut",
        },
        APART_START,
      );
    }
    if (phone) {
      tl.to(
        phone,
        { "--apart-ph": APART_PH + "px", duration: 0.6, ease: "power2.inOut" },
        APART_START,
      );
    }
    tl.to(
      devices,
      {
        scale: MOB_END_SCALE,
        transformOrigin: "50% 50%",
        duration: 0.6,
        ease: "power2.inOut",
      },
      APART_START,
    );
    if (copy) {
      tl.fromTo(
        copy,
        { autoAlpha: 0 },
        { autoAlpha: 1, duration: 0.5, ease: "power2.out" },
        APART_START + 0.25,
      );
    }
  };

  // ── DESKTOP/TABLET ──
  mm.add(
    "(prefers-reduced-motion: no-preference) and (min-width: 761px)",
    () => {
      // Strona drewelomet na ekranie laptopa — inicjalizowana tylko na desktop/tablet.
      // Owinięte w try/catch: błąd inicjalizacji nie może zamrozić animacji Hero.
      const laptopRoot = q<HTMLElement>(
        ".hero__devices .screen--laptop .dw-root",
      );
      let site: LaptopSiteApi | null = null;
      try {
        if (laptopRoot) site = initLaptopSite(laptopRoot);
      } catch (e) {
        console.error("[LaptopSite] init failed:", e);
        site = null;
      }

      const phoneRoot = q<HTMLElement>(
        ".hero__devices .screen--phone .dwm-root",
      );
      let phoneSite: PhoneSiteApi | null = null;
      try {
        if (phoneRoot) phoneSite = initPhoneSite(phoneRoot);
      } catch (e) {
        console.error("[PhoneSite] init failed:", e);
        phoneSite = null;
      }

      // 12 ekranów osi (intro ≈ 1,8 ekr., faza 3 ≈ 10 ekr. nakłada się na morf);
      // bez site — 4 jak dawniej.
      const b = buildBase(site ? 12 : 4);
      if (!b) {
        site?.destroy();
        phoneSite?.destroy();
        return;
      }
      const refs = deviceRefs();
      phase1Desktop(b);
      phase2Desktop(b, refs);
      if (site) phase3Desktop(b, site);
      if (site && phoneSite) phase3PhoneDesktop(b, phoneSite);
      return () => {
        cleanup(b)();
        site?.destroy();
        phoneSite?.destroy();
      };
    },
  );

  // ── MOBILE ──
  mm.add(
    "(prefers-reduced-motion: no-preference) and (max-width: 760px)",
    () => {
      const b = buildBase(4);
      if (!b) return;
      const refs = deviceRefs();
      const fitEl = q(".hero__devices .fit");

      const fitScale = () =>
        fitEl ? parseFloat(fitEl.style.getPropertyValue("--fit")) || 1 : 1;
      // offset poziomy ≈ szerokość viewportu / skala .fit (urządzenie za krawędzią)
      const slide = () =>
        (devicesEl?.clientWidth || window.innerWidth) / fitScale();
      // głębia wjazdu w jednostkach projektowych (≈ stała głębia ekranowa pod perspektywą)
      const Z_PX = 340;
      const zDepth = () => Z_PX / fitScale();

      phase1Mobile(b, refs, slide, zDepth);
      phase2Mobile(b, refs);

      return () => {
        cleanup(b)();
        refs.laptop?.style.setProperty("--sl-lap", "0px");
        refs.phone?.style.setProperty("--sl-ph", "0px");
        refs.laptop?.style.setProperty("--sz-lap", "0px");
        refs.phone?.style.setProperty("--sz-ph", "0px");
      };
    },
  );
</script>
