---
import { useTranslations, type Lang } from "@/i18n/utils";
import DeviceScene from "./DeviceScene.astro";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const accentLetters = [...t("hero.headlineAccent")];
const accentN = accentLetters.length;

const s1LeadLines = t("hero.s1Lead").split("\n");
const s1Accent = t("hero.s1Accent");
const copyRows = [
  t("hero.s2"),
  t("hero.s3"),
  t("hero.s4"),
  t("hero.s6"),
  t("hero.s7"),
].map((s, idx) => ({
  num: String(idx + 2).padStart(2, "0"),
  lines: s.split("\n"),
}));

const splitAccent = (line: string) =>
  line.split("*").map((part, j) => ({
    text: part.replace(/^!/, ""),
    em: j % 2 === 1,
    lg: j % 2 === 1 && part.startsWith("!"),
  }));
---

<section id="hero" class="hero">
  <div class="hero__stage">
    <div class="hero__head">
      <p class="hero__eyebrow">{t("hero.eyebrow")}</p>
      <h1 class="hero__headline">
        {t("hero.headlineLead")}{" "}
        <span class="hero__accent hero__accent--ghost" style={`--n:${accentN}`}>
          {
            accentLetters.map((ch, i) => (
              <span class="hero__accent-ltr" style={`--i:${i}`}>
                {ch === " " ? " " : ch}
              </span>
            ))
          }
        </span>
      </h1>

      <div class="hero__scroll">
        <span class="hero__scroll-label">{t("hero.scroll")}</span>
        <span class="hero__scroll-line" aria-hidden="true"></span>
      </div>
    </div>

    <span
      class="hero__accent hero__accent--live"
      aria-hidden="true"
      style={`--n:${accentN}`}
    >
      {
        accentLetters.map((ch, i) => (
          <span class="hero__accent-ltr" style={`--i:${i}`}>
            {ch === " " ? " " : ch}
          </span>
        ))
      }
    </span>

    <div class="hero__copy">
      <div class="hero__copy-row hero__copy-row--1">
        <span class="hero__copy-num">01</span>
        <p class="hero__copy-text">
          {
            s1LeadLines.map((line, i) => (
              <Fragment>
                {i > 0 && <br />}
                {line}
                {i === s1LeadLines.length - 1 && (
                  <Fragment>
                    {" "}
                    <em>{s1Accent}</em>
                  </Fragment>
                )}
              </Fragment>
            ))
          }
        </p>
      </div>
      {
        copyRows.map((row, idx) => (
          <div class={`hero__copy-row hero__copy-row--${idx + 2}`}>
            <span class="hero__copy-num">{row.num}</span>
            <p class="hero__copy-text">
              {row.lines.map((line, i) => (
                <Fragment>
                  {i > 0 && <br />}
                  <span
                    class={
                      i === 0
                        ? "hero__copy-ln"
                        : "hero__copy-ln hero__copy-ln--cont"
                    }
                  >
                    {splitAccent(line).map((p) =>
                      p.em ? (
                        <em class={p.lg ? "is-lg" : undefined}>{p.text}</em>
                      ) : (
                        p.text
                      ),
                    )}
                  </span>
                </Fragment>
              ))}
            </p>
          </div>
        ))
      }
    </div>

    <div class="hero__devices" aria-hidden="true">
      <DeviceScene />
    </div>

    <div class="hero__progress" aria-hidden="true">
      <span class="hero__progress-track"></span>
      <span class="hero__progress-seg"></span>
      <span class="hero__progress-seg"></span>
      <span class="hero__progress-dot"></span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;

    --headline-size: clamp(2.75rem, 7.9vw, 9.4rem);
  }

  .hero__stage {
    position: relative;
  }

  .hero__head {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(1.5rem, 2.1vw, 2.5rem);
    padding: 0 clamp(1.5rem, 9.4vw, 11.25rem);
    text-align: center;
  }

  .hero__eyebrow {
    margin: 0;
    font-family: var(--font-mono), monospace;
    font-size: clamp(0.62rem, 0.66vw, 0.75rem);
    letter-spacing: 0.44em;
    text-indent: 0.44em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .hero__headline {
    margin: 0;
    max-width: 18ch;
    font-family: var(--font-display), sans-serif;
    font-weight: 800;
    font-size: var(--headline-size);
    line-height: 1.04;
    letter-spacing: -0.035em;
    color: var(--ink);
    text-wrap: balance;
  }

  .hero__accent {
    --n: 1;
    font-family: var(--font-serif), serif;
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0;
    white-space: nowrap;
  }
  .hero__headline .hero__accent {
    font-size: 1.06em;
  }
  .hero__accent--live {
    display: none;
    font-size: calc(var(--headline-size) * 1.06);
  }

  .hero__accent-ltr {
    --i: 0;
    display: inline-block;
    padding: 0.3em 0.36em;
    margin: -0.3em -0.36em;
    background: var(--accent-gradient)
      calc(var(--i) / max(var(--n) - 1, 1) * 100%) 50% / calc(var(--n) * 100%)
      100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    animation: accent-wave 2.4s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.08s);
    will-change: transform;
  }
  .hero__accent--live.is-wave-paused .hero__accent-ltr {
    animation-play-state: paused;
  }

  .hero__scroll {
    position: absolute;
    bottom: clamp(1.25rem, 4vh, 2.75rem);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .hero__scroll-label {
    font-family: var(--font-mono), monospace;
    font-size: clamp(0.6rem, 0.6vw, 0.7rem);
    letter-spacing: 0.34em;
    text-indent: 0.34em;
    color: var(--faint);
  }
  .hero__scroll-line {
    width: 1px;
    height: clamp(2rem, 4.25vh, 2.875rem);
    background: linear-gradient(
      180deg,
      var(--accent) 0%,
      rgba(0, 0, 0, 0) 100%
    );
    transform-origin: top;
    animation: scroll-pulse 2.4s ease-in-out infinite;
  }

  .hero__copy {
    max-width: 40rem;
    margin: 0 auto;
    padding: clamp(2rem, 7vw, 5rem);
    display: flex;
    flex-direction: column;
  }
  .hero__copy-row {
    display: flex;
    gap: clamp(0.85rem, 1.4vw, 1.4rem);
    align-items: baseline;
  }
  .hero__copy-row--2,
  .hero__copy-row--3 {
    border-top: 1px solid var(--line);
    margin-top: clamp(1.1rem, 2vw, 1.65rem);
    padding-top: clamp(1.1rem, 2vw, 1.65rem);
  }
  .hero__copy-num {
    flex-shrink: 0;
    font-family: var(--font-mono), monospace;
    font-size: clamp(0.7rem, 0.8vw, 0.82rem);
    color: var(--accent);
  }
  .hero__copy-text {
    margin: 0;
    color: var(--muted);
    font-family: var(--font-display), sans-serif;
    font-weight: 600;
    font-size: clamp(1rem, 1.45vw, 1.65rem);
    line-height: 1.3;
    text-wrap: balance;
  }
  .hero__copy-row--1 .hero__copy-text {
    color: var(--ink);
    font-weight: 800;
    font-size: clamp(2rem, 3.9vw, 3.75rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }
  .hero__copy-text em {
    font-family: var(--font-serif), serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1.06em;
    letter-spacing: 0;
    padding-inline: 0.12em;
    margin-inline: -0.12em;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .hero__copy-text em.is-lg {
    font-size: 1.5em;
  }
  .hero__copy:not(.is-carousel) .hero__copy-row--4,
  .hero__copy:not(.is-carousel) .hero__copy-row--5,
  .hero__copy:not(.is-carousel) .hero__copy-row--6,
  .hero__copy:not(.is-carousel) .hero__copy-row--7 {
    display: none;
  }

  /* ─────────────────────────── SCENA URZĄDZEŃ (slot) ─────────────────────── */
  .hero__devices {
    position: relative;
    min-height: 100svh;
  }

  /* ───────────────── TRYB ANIMACJI (ruch dozwolony) ───────────────── */
  @media (prefers-reduced-motion: no-preference) {
    .hero {
      min-height: 700svh;
    }
    .hero__stage {
      position: sticky;
      top: 0;
      height: 100svh;
      overflow: clip;
    }
    .hero__head {
      position: absolute;
      inset: 0;
      min-height: auto;
      will-change: transform;
    }
    .hero__devices {
      position: absolute;
      inset: 0;
      min-height: auto;
      opacity: 0;
      will-change: transform, opacity;
    }
    .hero__accent--live {
      display: block;
      position: absolute;
      left: 0;
      top: 0;
      opacity: 0;
      z-index: 5;
      transform-origin: 50% 50%;
      pointer-events: none;
      will-change: transform, opacity;
    }

    .hero__copy {
      position: absolute;
      top: 50%;
      left: clamp(2.5rem, 7.5vw, 9.5rem);
      transform: translateY(-50%);
      width: clamp(18rem, 31vw, 31rem);
      max-width: none;
      margin: 0;
      padding: 0;
      opacity: 0;
      z-index: 4;
      pointer-events: none;
      will-change: transform, opacity;
    }

    .hero__copy.is-carousel {
      overflow-x: visible;
      overflow-y: clip;
    }
    .hero__copy.is-carousel .hero__copy-row {
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
      margin: 0;
      padding: 0;
      will-change: transform;
    }
    .hero__copy.is-carousel .hero__copy-row:not(.hero__copy-row--1) {
      border-top: 1px solid var(--line);
    }
    .hero__copy.is-carousel .hero__copy-text {
      color: var(--ink);
      white-space: nowrap;
    }
  }

  /* ─────────────────────── WSKAŹNIK POSTĘPU (mobile) ───────────────────────
     Domyślnie ukryty; odsłaniany wyłącznie w mobilnej gałęzi ruchu poniżej. */
  .hero__progress {
    display: none;
  }

  @media (prefers-reduced-motion: no-preference) and (max-width: 760px) {
    .hero {
      min-height: 1500svh;
    }

    .hero__progress {
      --p: 0;
      --bar-shift-y: -6svh;
      display: block;
      position: absolute;
      top: 50%;
      right: 12px;
      height: 72svh;
      width: 14px;
      transform: translateY(calc(-50% + var(--bar-shift-y)));
      z-index: 6;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.15s ease;
    }
    .hero__progress.is-active {
      opacity: 1;
    }
    .hero__progress-track {
      position: absolute;
      top: 0;
      bottom: 0;
      left: 50%;
      width: 2px;
      transform: translateX(-50%);
      background: var(--line);
      border-radius: 1px;
      z-index: 0;
    }
    .hero__progress-seg {
      --seg-top: 0; /* [0,1] — ustawia JS (setProperty) */
      --seg-h: 0;
      position: absolute;
      left: 50%;
      top: calc(var(--seg-top) * 100%);
      height: calc(var(--seg-h) * 100%);
      width: 2px;
      transform: translateX(-50%);
      background: var(--accent);
      border-radius: 1px;
      z-index: 1;
    }
    .hero__progress-dot {
      position: absolute;
      left: 50%;
      top: calc(var(--p) * 100%);
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--ink);
      box-shadow: 0 0 6px 1px rgba(245, 240, 236, 0.22);
      transform: translate(-50%, -50%);
      z-index: 3;
      transition:
        background-color 0.15s ease,
        box-shadow 0.15s ease;
    }
    /* na odcinku odtwarzania kulka przejmuje kolor akcentu */
    .hero__progress-dot.is-on-seg {
      background: var(--accent);
      box-shadow: 0 0 8px 1px rgba(var(--glow), 0.55);
    }
    .hero__progress.is-android .hero__progress-track {
      background: var(--accent);
    }
    .hero__progress.is-android .hero__progress-seg {
      display: none;
    }
    .hero__devices {
      z-index: 5;
    }
    .hero__copy {
      position: absolute;
      inset: 0;
      width: auto;
      left: 0;
      top: 0;
      transform: none;
      padding: 0;
      opacity: 0;
      z-index: 4;
      pointer-events: none;
      will-change: opacity;
    }
    .hero__copy-row {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      width: min(86vw, 26rem);
      margin: 0;
    }
    .hero__copy-row--1 {
      top: 7svh;
    }
    .hero__copy-row--2 {
      top: 45svh;
    }
    .hero__copy-row--3 {
      top: 82svh;
    }
    .hero__copy-row--3 .hero__copy-text br {
      display: none;
    }
    .hero__copy-row--3 .hero__copy-ln--cont {
      text-transform: lowercase;
    }
    .hero__copy-row--3 .hero__copy-ln--cont::before {
      content: " ";
    }
    .hero__copy-row--4,
    .hero__copy-row--5,
    .hero__copy-row--6,
    .hero__copy-row--7 {
      display: none;
    }
  }

  @media (prefers-reduced-motion: no-preference) and (min-width: 761px) {
    .hero {
      min-height: 1400svh;
    }
  }

  @keyframes scroll-pulse {
    0%,
    100% {
      opacity: 0.55;
      transform: scaleY(0.82);
    }
    50% {
      opacity: 1;
      transform: scaleY(1);
    }
  }

  @keyframes accent-wave {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-0.12em);
    }
  }

  @media (max-height: 600px) {
    .hero__eyebrow,
    .hero__scroll-label {
      display: none;
    }
    .hero {
      --headline-size: clamp(2.25rem, 6.4vw, 7.5rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-line,
    .hero__accent-ltr {
      animation: none;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import { initDeviceScene, FRAME_C } from "./device-scene";
  import { initLaptopSite, type LaptopSiteApi } from "./laptop-site";
  import { initPhoneSite, type PhoneSiteApi } from "./phone-site";
  import { IS_ANDROID, initAndroidPhase3 } from "./android-mobile";

  gsap.registerPlugin(ScrollTrigger);

  ScrollTrigger.config({ ignoreMobileResize: true });
  ScrollTrigger.normalizeScroll(true);

  if (IS_ANDROID) document.documentElement.classList.add("is-android");
  const devicesEl = document.querySelector<HTMLElement>(".hero__devices");
  const scene = devicesEl ? initDeviceScene(devicesEl) : null;

  /* ── Animacja sterowana scrollem (tylko gdy ruch dozwolony) ── */
  const mm = gsap.matchMedia();

  const q = <T extends HTMLElement = HTMLElement>(s: string) =>
    document.querySelector<T>(s);
  const buildBase = (screens: number) => {
    const hero = q("#hero");
    const stage = q(".hero__stage");
    const head = q(".hero__head");
    const ghost = q(".hero__accent--ghost");
    const live = q(".hero__accent--live");
    const devices = q(".hero__devices");
    const copy = q(".hero__copy");
    const scroll = q(".hero__scroll");
    if (!hero || !stage || !head || !ghost || !live || !devices) return null;

    const rect = () => {
      const g = ghost.getBoundingClientRect();
      const h = head.getBoundingClientRect();
      return {
        left: g.left - h.left,
        top: g.top - h.top,
        width: g.width,
        height: g.height,
      };
    };
    const startX = () => rect().left;
    const startY = () => rect().top;
    const endX = () => stage.clientWidth / 2 - rect().width / 2;
    const endY = () => stage.clientHeight / 2 - rect().height / 2;

    // ghost znika wizualnie, ale zostaje w drzewie dostępności (opacity, nie visibility)
    gsap.set(ghost, { opacity: 0 });

    const tl = gsap.timeline({
      defaults: { ease: "none" },
      scrollTrigger: {
        trigger: hero,
        start: "top top",
        end: () => "+=" + window.innerHeight * screens,
        scrub: true,
        invalidateOnRefresh: true,
        onUpdate: (self) =>
          live.classList.toggle("is-wave-paused", self.progress > 0.3),
      },
    });

    tl.to(head, { yPercent: -110, duration: 0.6 }, 0);
    if (scroll) tl.to(scroll, { autoAlpha: 0, duration: 0.12 }, 0);

    return {
      tl,
      ghost,
      live,
      devices,
      copy,
      scroll,
      startX,
      startY,
      endX,
      endY,
    };
  };

  type Base = NonNullable<ReturnType<typeof buildBase>>;
  // Refy urządzeń sceny — wspólne dla obu wariantów (selektory = kontrakt z DeviceScene).
  type DeviceRefs = {
    laptop: HTMLElement | null;
    phone: HTMLElement | null;
    camera: HTMLElement | null;
    base: HTMLElement | null;
  };
  const deviceRefs = (): DeviceRefs => ({
    laptop: q("[data-gsap='laptop']"),
    phone: q("[data-gsap='phone']"),
    camera: q(".hero__devices .camera"),
    base: q("[data-gsap='laptop-base']"),
  });

  const cleanup = (b: Base) => () => {
    b.tl.scrollTrigger?.kill();
    b.tl.kill();
    gsap.set([b.ghost, b.live, b.devices, b.copy, b.scroll].filter(Boolean), {
      clearProps: "all",
    });
    const { laptop: lp, phone: ph, camera: cam, base: bs } = deviceRefs();
    lp?.style.removeProperty("--lap-yaw");
    lp?.style.removeProperty("--lap-pitch");
    lp?.style.removeProperty("--apart-lap");
    ph?.style.removeProperty("--ph-dx");
    ph?.style.removeProperty("--ph-dy");
    ph?.style.removeProperty("--ph-dz");
    ph?.style.removeProperty("--apart-ph");
    cam?.style.removeProperty("--cx");
    cam?.style.removeProperty("--cy");
    if (bs) gsap.set(bs, { clearProps: "opacity" });
  };

  // ════════════════════════════ FAZY (desktop) ════════════════════════════

  const PH3_START = 0.9;
  const DREWELOMET_DUR = 5.0;
  const phase1Desktop = (b: Base) => {
    const { tl, live, devices, startX, startY, endX, endY } = b;
    tl.fromTo(
      live,
      { x: startX, y: startY, scale: 1, filter: "blur(0px)", autoAlpha: 1 },
      {
        x: endX,
        y: endY,
        scale: 5.2,
        filter: "blur(24px)",
        duration: 0.5,
        ease: "power1.in",
      },
      0.15,
    );
    tl.to(live, { autoAlpha: 0, duration: 0.13 }, 0.56);

    tl.fromTo(
      devices,
      { autoAlpha: 0, filter: "blur(26px)", scale: 1.22 },
      {
        autoAlpha: 1,
        filter: "blur(0px)",
        scale: 1,
        duration: 0.38,
        ease: "power2.out",
      },
      0.5,
    );
  };

  const phase2Desktop = (b: Base, refs: DeviceRefs) => {
    const { tl, copy, devices } = b;
    const { laptop, phone, camera, base } = refs;
    const PH2 = 0.95; // start fazy 2 na osi timeline (po wejściu urządzeń)

    if (phone) {
      tl.to(
        phone,
        {
          "--ph-dx": FRAME_C.phDx + "px",
          "--ph-dy": FRAME_C.phDy + "px",
          "--ph-dz": FRAME_C.phDz + "px",
          duration: 0.5,
          ease: "power2.inOut",
        },
        PH2,
      );
    }
    if (base) {
      tl.to(
        base,
        { autoAlpha: 0, duration: 0.4, ease: "power2.inOut" },
        PH2 + 0.03,
      );
    }
    // (c) ruch kamery B→C + skręt (yaw) i odchylenie do tyłu (pitch) laptopa
    if (camera) {
      tl.to(
        camera,
        {
          "--cx": FRAME_C.camCx + "deg",
          "--cy": FRAME_C.camCy + "deg",
          duration: 0.5,
          ease: "power2.inOut",
        },
        PH2 + 0.45,
      );
    }
    if (laptop) {
      tl.to(
        laptop,
        {
          "--lap-yaw": FRAME_C.lapYaw + "deg",
          "--lap-pitch": FRAME_C.lapPitch + "deg",
          duration: 0.5,
          ease: "power2.inOut",
        },
        PH2 + 0.45,
      );
    }
    tl.to(
      devices,
      {
        x: () => scene?.getFrameC().x ?? 0,
        scale: () => scene?.getFrameC().scale ?? 1,
        transformOrigin: "50% 50%",
        duration: 1.0,
        ease: "power2.inOut",
      },
      PH2,
    );
    if (copy) {
      tl.fromTo(
        copy,
        { autoAlpha: 0, x: -48 },
        { autoAlpha: 1, x: 0, duration: 0.6, ease: "power2.out" },
        PH2 + 0.35,
      );
    }
  };

  const phase3Desktop = (b: Base, site: LaptopSiteApi) => {
    const { tl } = b;
    const p = { v: 0 };
    tl.to(
      p,
      {
        v: 1,
        ease: "none",
        duration: DREWELOMET_DUR,
        onUpdate: () => site.master.progress(p.v),
        onStart: () => site.setActive(true),
        onComplete: () => site.setActive(false),
        onReverseComplete: () => site.setActive(false),
      },
      PH3_START,
    );
  };

  const phase3PhoneDesktop = (b: Base, phone: PhoneSiteApi) => {
    const { tl } = b;
    const PHONE_START = 2.0;
    const PHONE_END = 5.9;
    const p = { v: 0 };
    tl.to(
      p,
      {
        v: 1,
        ease: "none",
        duration: PHONE_END - PHONE_START,
        onUpdate: () => phone.master.progress(p.v),
        onStart: () => phone.setActive(true),
        onComplete: () => phone.setActive(false),
        onReverseComplete: () => phone.setActive(false),
      },
      PHONE_START,
    );
  };

  const initCaptionCarousel = (b: Base) => {
    const copy = b.copy;
    if (!copy) return () => {};
    const rows = Array.from(
      copy.querySelectorAll<HTMLElement>(".hero__copy-row"),
    );
    const maybeTexts = rows.map((r) =>
      r.querySelector<HTMLElement>(".hero__copy-text"),
    );
    if (rows.length < 3 || maybeTexts.some((t) => !t)) return () => {};
    const texts = maybeTexts as HTMLElement[];

    copy.classList.add("is-carousel");

    const CAP_START = 1.95;
    const DOG_PROGRESS = 0.934;
    const CAP_END = PH3_START + DREWELOMET_DUR * DOG_PROGRESS;
    const PHASE_A_FRAC = 0.14;
    const REST_BIG_SCALE = 0.53;
    const REST_SMALL_SCALE = 1;
    const MIN_GROW = 0.98;
    const LOW_OPACITY = 0.05;
    const MORPH_A0 = 1;
    const MORPH_A1 = 2;
    const CONTAINER_EXTRA = 110;
    const FIRST_GAP_EXTRA = 110;
    const LAST_BIG_SCALE = 1;

    const N = rows.length;
    let smallPx = 16;
    let bigPx = 40;
    let bigPxRest = 34;
    let GAP = 18;
    let Cy = 0;
    let big0H = 0;
    let p1MinH = 0;

    const bigOf = (i: number) =>
      i === 0 ? bigPx : i === N - 1 ? bigPx * LAST_BIG_SCALE : bigPxRest;
    const smallOf = (i: number) =>
      i === 0 ? smallPx : smallPx * REST_SMALL_SCALE;

    const smallH = new Array<number>(N).fill(0);
    const bigH = new Array<number>(N).fill(0);
    const g = new Array<number>(N).fill(0);
    const h = new Array<number>(N).fill(0);
    const center = new Array<number>(N).fill(0);
    const lastFont = new Array<string>(N).fill("");
    const lastWeight = new Array<string>(N).fill("");
    const lastOpacity = new Array<string>(N).fill("");
    const lastTransform = new Array<string>(N).fill("");

    const measure = () => {
      const t0 = texts[0];
      const t1 = texts[1];
      const p0 = t0.style.fontSize;
      const p1 = t1.style.fontSize;
      t0.style.fontSize = "";
      t1.style.fontSize = "";
      bigPx = parseFloat(getComputedStyle(t0).fontSize) || 40;
      bigPxRest = bigPx * REST_BIG_SCALE;
      smallPx = parseFloat(getComputedStyle(t1).fontSize) || 16;
      t0.style.fontSize = p0;
      t1.style.fontSize = p1;
      const rootPx =
        parseFloat(getComputedStyle(document.documentElement).fontSize) || 16;
      const rowSpace = Math.max(
        1.1 * rootPx,
        Math.min(0.02 * window.innerWidth, 1.65 * rootPx),
      );
      GAP = Math.round(2 * rowSpace);
      for (let i = 0; i < N; i++) {
        const tx = texts[i];
        const prev = tx.style.fontSize;
        tx.style.fontSize = smallOf(i) + "px";
        smallH[i] = rows[i].offsetHeight;
        tx.style.fontSize = bigOf(i) + "px";
        bigH[i] = rows[i].offsetHeight;
        tx.style.fontSize = prev;
        lastFont[i] = lastWeight[i] = lastOpacity[i] = lastTransform[i] = "";
      }
      big0H = bigH[0];
      p1MinH =
        smallH[0] +
        (bigH[0] - smallH[0]) * ((bigPxRest - smallPx) / (bigPx - smallPx));
      const H = bigH[0] + 2 * GAP + smallH[1] + smallH[2] + CONTAINER_EXTRA;
      Cy = H / 2;
      copy.style.height = H + "px";
    };

    const clamp01 = (x: number) => (x < 0 ? 0 : x > 1 ? 1 : x);
    const smoother = (t: number) => t * t * t * (t * (t * 6 - 15) + 10);

    const render = (u: number) => {
      let A =
        u <= PHASE_A_FRAC
          ? u / PHASE_A_FRAC
          : 1 + ((u - PHASE_A_FRAC) / (1 - PHASE_A_FRAC)) * (N - 2);
      if (A < 0) A = 0;
      else if (A > N - 1) A = N - 1;

      const m = smoother(clamp01((A - MORPH_A0) / (MORPH_A1 - MORPH_A0)));
      const grow = MIN_GROW * m;
      const lastFade = smoother(clamp01(A - (N - 2)));
      const minOp = (0.58 + (LOW_OPACITY - 0.58) * m) * (1 - lastFade);

      let top = 0;
      for (let i = 0; i < N; i++) {
        g[i] = smoother(clamp01(1 - Math.abs(i - A)));
        const sH = i === 0 ? p1MinH : smallH[i] + (bigH[i] - smallH[i]) * grow;
        h[i] = sH + (bigH[i] - sH) * g[i];
        center[i] = top + h[i] / 2;
        top += h[i] + GAP + (i === 0 ? FIRST_GAP_EXTRA : 0);
      }

      const lo = Math.floor(A);
      const hi = lo + 1 < N ? lo + 1 : N - 1;
      const anchorRaw = center[lo] + (center[hi] - center[lo]) * (A - lo);
      const anchorY = A <= 1 ? big0H / 2 + (Cy - big0H / 2) * A : Cy;
      const offset = anchorY - anchorRaw;

      for (let i = 0; i < N; i++) {
        const gi = g[i];
        const sPx =
          i === 0 ? bigPxRest : smallOf(i) + (bigOf(i) - smallOf(i)) * grow;

        const font = (sPx + (bigOf(i) - sPx) * gi).toFixed(2) + "px";
        if (font !== lastFont[i]) {
          texts[i].style.fontSize = font;
          lastFont[i] = font;
        }
        const weight = "" + Math.round(600 + 200 * gi);
        if (weight !== lastWeight[i]) {
          texts[i].style.fontWeight = weight;
          lastWeight[i] = weight;
        }
        const opacity = (minOp + (1 - minOp) * gi).toFixed(3);
        if (opacity !== lastOpacity[i]) {
          rows[i].style.opacity = opacity;
          lastOpacity[i] = opacity;
        }
        const transform =
          "translateY(" + (center[i] + offset - h[i] / 2).toFixed(2) + "px)";
        if (transform !== lastTransform[i]) {
          rows[i].style.transform = transform;
          lastTransform[i] = transform;
        }
      }
    };

    measure();
    render(0);

    const capProxy = { u: 0 };
    b.tl.to(
      capProxy,
      {
        u: 1,
        ease: "none",
        duration: CAP_END - CAP_START,
        onUpdate: () => render(capProxy.u),
      },
      CAP_START,
    );

    const onRefresh = () => {
      measure();
      render(capProxy.u);
    };
    ScrollTrigger.addEventListener("refresh", onRefresh);
    document.fonts?.ready.then(() => {
      measure();
      render(capProxy.u);
      ScrollTrigger.refresh();
    });

    return () => {
      ScrollTrigger.removeEventListener("refresh", onRefresh);
      copy.classList.remove("is-carousel");
      copy.style.removeProperty("height");
      rows.forEach((r, i) => {
        r.style.removeProperty("opacity");
        r.style.removeProperty("transform");
        texts[i].style.removeProperty("font-size");
        texts[i].style.removeProperty("font-weight");
      });
    };
  };

  // ════════════════════════════ FAZY (mobile) ═════════════════════════════

  // Wspólne okno "osadzania" urządzeń: wjazd z boków ORAZ rozsunięcie/pomniejszenie
  // dzielą ten sam start i czas, więc całość to jeden ciągły ruch (zero martwego
  // punktu — urządzenia już w trakcie wjazdu zmierzają do finalnej pozycji i skali).
  const MOB_SETTLE_START = 0.5; // start po zaniku słowa "Ciebie"
  const MOB_SETTLE_DUR = 0.9; // krócej niż dawne 1.4 (wjazd 0.7 + przerwa + 0.6)
  const MOB_SETTLE_EASE = "power3.out"; // snappy dolot, wspólny dla wszystkich torów

  const phase1Mobile = (
    b: Base,
    refs: DeviceRefs,
    slide: () => number,
    zDepth: () => number,
  ) => {
    const { tl, live, devices, startX, startY } = b;
    const { laptop, phone } = refs;

    // słowo: hold w miejscu, potem sam zanik (bez skali/blura/przejazdu)
    tl.fromTo(
      live,
      { x: startX, y: startY, scale: 1, autoAlpha: 1 },
      { autoAlpha: 0, duration: 0.17 },
      0.45,
    );

    gsap.set(devices, { autoAlpha: 1, filter: "none", scale: 1 });
    if (laptop) {
      tl.fromTo(
        laptop,
        { "--sl-lap": () => slide() + "px" },
        { "--sl-lap": "0px", duration: MOB_SETTLE_DUR, ease: MOB_SETTLE_EASE },
        MOB_SETTLE_START,
      );
      tl.fromTo(
        laptop,
        { "--sz-lap": () => -zDepth() + "px" },
        { "--sz-lap": "0px", duration: MOB_SETTLE_DUR, ease: MOB_SETTLE_EASE },
        MOB_SETTLE_START,
      );
    }
    if (phone) {
      tl.fromTo(
        phone,
        { "--sl-ph": () => -slide() + "px" },
        { "--sl-ph": "0px", duration: MOB_SETTLE_DUR, ease: MOB_SETTLE_EASE },
        MOB_SETTLE_START,
      );
      tl.fromTo(
        phone,
        { "--sz-ph": () => zDepth() + "px" },
        { "--sz-ph": "0px", duration: MOB_SETTLE_DUR, ease: MOB_SETTLE_EASE },
        MOB_SETTLE_START,
      );
    }
  };

  const phase2Mobile = (b: Base, refs: DeviceRefs) => {
    const { tl, copy, devices } = b;
    const { laptop, phone } = refs;
    // Scalone z wjazdem: rozsunięcie + pomniejszenie biegną RAZEM z fazą 1
    // (ten sam start/czas/ease) → jeden ciągły ruch, bez etapu pośredniego.
    const APART_START = MOB_SETTLE_START;
    const K = IS_ANDROID ? 0.6 : 1;
    const APART_LAP = -150 * K; // laptop w górę (px projektu)
    const APART_PH = 170 * K; // telefon w dół (px projektu)
    const MOB_END_SCALE = 0.82; // pomniejszenie grupy (miejsce na tekst góra/dół)

    if (laptop) {
      tl.to(
        laptop,
        {
          "--apart-lap": APART_LAP + "px",
          duration: MOB_SETTLE_DUR,
          ease: MOB_SETTLE_EASE,
        },
        APART_START,
      );
    }
    if (phone) {
      tl.to(
        phone,
        {
          "--apart-ph": APART_PH + "px",
          duration: MOB_SETTLE_DUR,
          ease: MOB_SETTLE_EASE,
        },
        APART_START,
      );
    }
    tl.to(
      devices,
      {
        scale: MOB_END_SCALE,
        transformOrigin: "50% 50%",
        duration: MOB_SETTLE_DUR,
        ease: MOB_SETTLE_EASE,
      },
      APART_START,
    );
    if (copy) {
      // copy wjeżdża wraz z dolotem urządzeń i domyka się tuż po osadzeniu
      tl.fromTo(
        copy,
        { autoAlpha: 0 },
        { autoAlpha: 1, duration: 0.5, ease: "power2.out" },
        APART_START + MOB_SETTLE_DUR - 0.4,
      );
    }
  };

  // ── DESKTOP/TABLET ──
  mm.add(
    "(prefers-reduced-motion: no-preference) and (min-width: 761px)",
    () => {
      // Strona drewelomet na ekranie laptopa — inicjalizowana tylko na desktop/tablet.
      // Owinięte w try/catch: błąd inicjalizacji nie może zamrozić animacji Hero.
      const laptopRoot = q<HTMLElement>(
        ".hero__devices .screen--laptop .dw-root",
      );
      let site: LaptopSiteApi | null = null;
      try {
        if (laptopRoot) site = initLaptopSite(laptopRoot);
      } catch (e) {
        console.error("[LaptopSite] init failed:", e);
        site = null;
      }

      const phoneRoot = q<HTMLElement>(
        ".hero__devices .screen--phone .dwm-root",
      );
      let phoneSite: PhoneSiteApi | null = null;
      try {
        if (phoneRoot) phoneSite = initPhoneSite(phoneRoot);
      } catch (e) {
        console.error("[PhoneSite] init failed:", e);
        phoneSite = null;
      }

      const b = buildBase(site ? 12 : 4);
      if (!b) {
        site?.destroy();
        phoneSite?.destroy();
        return;
      }
      const refs = deviceRefs();
      const captionCleanup = site ? initCaptionCarousel(b) : null;
      phase1Desktop(b);
      phase2Desktop(b, refs);
      if (site) phase3Desktop(b, site);
      if (site && phoneSite) phase3PhoneDesktop(b, phoneSite);
      return () => {
        captionCleanup?.();
        cleanup(b)();
        site?.destroy();
        phoneSite?.destroy();
      };
    },
  );

  // ── MOBILE ──
  mm.add(
    "(prefers-reduced-motion: no-preference) and (max-width: 760px)",
    () => {
      // Odchudzenie DOM: żywe podglądy stron (ciężkie poddrzewa + obrazy) są na
      // mobile niepotrzebne — ekrany napędza video. Usuwamy je całkiem z DOM.
      q(".hero__devices .screen--laptop .dw-root")?.remove();
      q(".hero__devices .screen--phone .dwm-root")?.remove();

      const b = buildBase(4);
      if (!b) return;
      const refs = deviceRefs();
      const fitEl = q(".hero__devices .fit");

      const fitScale = () =>
        fitEl ? parseFloat(fitEl.style.getPropertyValue("--fit")) || 1 : 1;
      // offset poziomy ≈ szerokość viewportu / skala .fit (urządzenie za krawędzią)
      const slide = () =>
        (devicesEl?.clientWidth || window.innerWidth) / fitScale();
      // głębia wjazdu w jednostkach projektowych (≈ stała głębia ekranowa pod perspektywą)
      const Z_PX = 340;
      const zDepth = () => Z_PX / fitScale();

      phase1Mobile(b, refs, slide, zDepth);
      phase2Mobile(b, refs);

      const hero = q("#hero");
      const setupVideo = (sel: string) => {
        const v = q<HTMLVideoElement>(sel);
        if (v && v.dataset.src && !v.src) {
          v.preload = "auto";
          v.src = v.dataset.src;
          v.load();
        }
        return v;
      };
      const stopReset = (v: HTMLVideoElement | null) => {
        if (!v) return;
        try {
          v.pause();
          v.currentTime = 0;
        } catch {
          /* noop */
        }
      };

      const lapVideo = setupVideo("[data-gsap='video-laptop']");
      const phVideo = setupVideo("[data-gsap='video-phone']");

      const VID_MAX = 1.5; // docelowe powiększenie w szczycie strefy
      const GROW_END = 1 / 4; // szczyt — koniec powiększania, start przytrzymania
      const HOLD_END = 3 / 4; // koniec przytrzymania (~2 ekrany) — start zmniejszania

      const LAP_ZONE = { start: 4.4, end: 8.4 };
      const PH_ZONE = { start: 8.8, end: 12.8 };

      // ── Wzrost tekstów 02/03 (mobile, wspólny iOS + Android) ──────────────
      // Spójnie z desktopową karuzelą: powiększenie + szary→biały + 600→800.
      // Geometria przez transform: scale z origin lewo-środek → tekst rośnie
      // w prawo i równomiernie w górę/dół, lewa krawędź stoi, zero reflow
      // (nic innego się nie przesuwa). Sterowane scrubem → w pełni odwracalne.
      const initCaptionGrowth = () => {
        if (!hero) return () => {};
        const t1 = q<HTMLElement>(".hero__copy-row--1 .hero__copy-text");
        const t2 = q<HTMLElement>(".hero__copy-row--2 .hero__copy-text");
        const t3 = q<HTMLElement>(".hero__copy-row--3 .hero__copy-text");
        if (!t1 || !t2 || !t3) return () => {};

        const muted = getComputedStyle(t2).color; // bazowy szary 02/03
        const ink = getComputedStyle(t1).color; // biel tekstu 01

        // Docelowa "część drogi" z rozmiaru bazowego do rozmiaru 01.
        // 02 rośnie w połowę drogi; 03 ("Płynnie…") mniej, bo dłuższy tekst
        // wystawałby poza kontener z prawej.
        const REACH_02 = 0.5;
        const REACH_03 = 0.3;
        // transform nie zmienia computed font-size, więc odczyt jest zawsze
        // rozmiarem bazowym niezależnie od bieżącej skali (bezpieczne przy refresh).
        const targetScale = (base: HTMLElement, reach: number) => {
          const s0 = parseFloat(getComputedStyle(t1).fontSize) || 32;
          const sb = parseFloat(getComputedStyle(base).fontSize) || 16;
          return 1 + reach * (s0 / sb - 1);
        };

        // Czerwony odcinek = faza odtwarzania wideo [play, end] na pasku postępu.
        const playStart = (z: { start: number; end: number }) =>
          z.start + GROW_END * (z.end - z.start);
        // Okno wzrostu = pierwsze GROW_FRACTION długości czerwonego odcinka.
        // Mniejsza wartość = teksty szybciej osiągają maksymalny rozmiar.
        const GROW_FRACTION = 0.18;
        const growEndVh = (z: { start: number; end: number }) => {
          const p = playStart(z);
          return p + GROW_FRACTION * (z.end - p);
        };

        const make = (
          text: HTMLElement,
          z: { start: number; end: number },
          reach: number,
        ) =>
          gsap.fromTo(
            text,
            { scale: 1, color: muted, fontWeight: 600 },
            {
              scale: () => targetScale(text, reach),
              color: ink,
              fontWeight: 800,
              transformOrigin: "0% 50%",
              ease: "none",
              scrollTrigger: {
                trigger: hero,
                start: () =>
                  "top+=" + playStart(z) * window.innerHeight + " top",
                end: () => "top+=" + growEndVh(z) * window.innerHeight + " top",
                scrub: true,
                invalidateOnRefresh: true,
              },
            },
          );

        const tweens = [
          make(t2, LAP_ZONE, REACH_02),
          make(t3, PH_ZONE, REACH_03),
        ];

        return () => {
          tweens.forEach((tw) => {
            tw.scrollTrigger?.kill();
            tw.kill();
          });
          [t2, t3].forEach((t) => {
            t.style.removeProperty("transform");
            t.style.removeProperty("color");
            t.style.removeProperty("font-weight");
          });
        };
      };
      const captionGrowthCleanup = initCaptionGrowth();

      const stageEl = q(".hero__stage");
      const div02 = q<HTMLElement>(".hero__copy-row--2");
      const div03 = q<HTMLElement>(".hero__copy-row--3");
      const GAP_LAP_DIV = 23; // px viewportu (laptop.bottom → div02)
      const GAP_PH_DIV = 21; // px viewportu (phone.bottom → div03)
      const placeDividers = () => {
        if (!stageEl) return;
        const stageTop = stageEl.getBoundingClientRect().top;
        if (refs.laptop && div02) {
          const lapBottom =
            refs.laptop.getBoundingClientRect().bottom - stageTop;
          div02.style.top = lapBottom + GAP_LAP_DIV + "px";
        }
        if (refs.phone && div03) {
          const phBottom = refs.phone.getBoundingClientRect().bottom - stageTop;
          div03.style.top = phBottom + GAP_PH_DIV + "px";
        }
      };
      const dividerTrigger =
        IS_ANDROID && hero
          ? ScrollTrigger.create({
              trigger: hero,
              start: "top top",
              end: () => "top+=" + LAP_ZONE.start * window.innerHeight + " top",
              onUpdate: placeDividers,
              onLeave: placeDividers,
              onLeaveBack: placeDividers,
            })
          : null;
      if (IS_ANDROID) {
        ScrollTrigger.addEventListener("refresh", placeDividers);
        placeDividers();
      }
      const cleanupDividers = () => {
        dividerTrigger?.kill();
        ScrollTrigger.removeEventListener("refresh", placeDividers);
        div02?.style.removeProperty("top");
        div03?.style.removeProperty("top");
      };

      // ── Wskaźnik postępu (kuleczka + pasek) — wspólne refy dla obu wariantów.
      const progressEl = q(".hero__progress");
      const progressDot = q(".hero__progress-dot");
      if (IS_ANDROID) {
        const androidCleanup = initAndroidPhase3({
          hero,
          vidMax: VID_MAX,
          growEnd: GROW_END,
          holdEnd: HOLD_END,
          videos: [
            { video: lapVideo, el: refs.laptop, zone: LAP_ZONE },
            { video: phVideo, el: refs.phone, zone: PH_ZONE },
          ],
          progressEl,
          progressDot,
          barStartVh: LAP_ZONE.start,
          barEndVh: PH_ZONE.end,
        });

        return () => {
          cleanup(b)();
          androidCleanup();
          captionGrowthCleanup();
          cleanupDividers();
          stopReset(lapVideo);
          stopReset(phVideo);
          refs.laptop?.style.setProperty("--vid-scale", "1");
          refs.phone?.style.setProperty("--vid-scale", "1");
          refs.laptop?.style.setProperty("--sl-lap", "0px");
          refs.phone?.style.setProperty("--sl-ph", "0px");
          refs.laptop?.style.setProperty("--sz-lap", "0px");
          refs.phone?.style.setProperty("--sz-ph", "0px");
        };
      }
      let autoplayBlocked = false;

      const makeVideoZone = (
        video: HTMLVideoElement | null,
        el: HTMLElement | null,
        startVh: number,
        endVh: number,
      ) => {
        if (!hero || !video || !el) return null;
        let lastScale = -1;
        let playRequested = false;
        const setScale = (s: number) => {
          if (s === lastScale) return;
          lastScale = s;
          el.style.setProperty("--vid-scale", s.toFixed(4));
        };
        return ScrollTrigger.create({
          trigger: hero,
          start: () => "top+=" + startVh * window.innerHeight + " top",
          end: () => "top+=" + endVh * window.innerHeight + " top",
          scrub: true,
          onUpdate: (self) => {
            const p = self.progress;
            // 1→MAX (grow) | MAX (hold) | MAX→1 (shrink)
            let s: number;
            if (p <= GROW_END) s = 1 + (VID_MAX - 1) * (p / GROW_END);
            else if (p < HOLD_END) s = VID_MAX;
            else s = 1 + (VID_MAX - 1) * ((1 - p) / (1 - HOLD_END));
            setScale(s);
            // odtwarzanie od szczytu (koniec powiększania) do bazy: [GROW_END, 1)
            if (p >= GROW_END && p < 1) {
              if (!playRequested && !autoplayBlocked) {
                playRequested = true; // próbuj raz na wejście, nie co klatkę
                video.currentTime = 0;
                video.play()?.catch(() => {
                  // autoplay zablokowany (np. iOS Low Power Mode) → plakat,
                  // bez ponawiania dla obu wideo
                  autoplayBlocked = true;
                });
              }
            } else {
              playRequested = false;
              if (!video.paused) {
                video.pause();
                video.currentTime = 0;
              }
            }
          },
          onLeave: () => {
            playRequested = false;
            setScale(1);
            stopReset(video);
          },
          onLeaveBack: () => {
            playRequested = false;
            setScale(1);
            stopReset(video);
          },
        });
      };

      const zoneTriggers = [
        makeVideoZone(lapVideo, refs.laptop, LAP_ZONE.start, LAP_ZONE.end),
        makeVideoZone(phVideo, refs.phone, PH_ZONE.start, PH_ZONE.end),
      ].filter(Boolean) as ScrollTrigger[];
      const BAR_SPAN = PH_ZONE.end - LAP_ZONE.start;
      const barP = (vh: number) => (vh - LAP_ZONE.start) / BAR_SPAN;
      const playStartVh = (z: { start: number; end: number }) =>
        z.start + GROW_END * (z.end - z.start);
      const segs = [LAP_ZONE, PH_ZONE].map((z) => ({
        play: barP(playStartVh(z)),
        stop: barP(z.end),
      }));

      // Odcinki są statyczne w markupie (2× seg) — tu tylko ustawiamy pozycje.
      const segEls = progressEl
        ? [...progressEl.querySelectorAll<HTMLElement>(".hero__progress-seg")]
        : [];
      segs.forEach((s, i) => {
        segEls[i]?.style.setProperty("--seg-top", s.play.toFixed(4));
        segEls[i]?.style.setProperty("--seg-h", (s.stop - s.play).toFixed(4));
      });

      const updateDot = (p: number) => {
        // kulka przejmuje kolor akcentu, gdy jest na którymś odcinku odtwarzania
        const onSeg = segs.some((s) => p >= s.play && p <= s.stop);
        progressDot?.classList.toggle("is-on-seg", onSeg);
      };
      updateDot(0);

      const progressTrigger =
        hero && progressEl
          ? ScrollTrigger.create({
              trigger: hero,
              start: () =>
                "top+=" + LAP_ZONE.start * window.innerHeight + " top",
              end: () => "top+=" + PH_ZONE.end * window.innerHeight + " top",
              scrub: true,
              onUpdate: (self) => {
                progressEl.style.setProperty("--p", self.progress.toFixed(4));
                updateDot(self.progress);
              },
              onToggle: (self) =>
                progressEl.classList.toggle("is-active", self.isActive),
            })
          : null;

      return () => {
        cleanup(b)();
        captionGrowthCleanup();
        cleanupDividers();
        zoneTriggers.forEach((t) => t.kill());
        progressTrigger?.kill();
        progressEl?.classList.remove("is-active");
        progressEl?.style.removeProperty("--p");
        progressDot?.classList.remove("is-on-seg");
        stopReset(lapVideo);
        stopReset(phVideo);
        refs.laptop?.style.setProperty("--vid-scale", "1");
        refs.phone?.style.setProperty("--vid-scale", "1");
        refs.laptop?.style.setProperty("--sl-lap", "0px");
        refs.phone?.style.setProperty("--sl-ph", "0px");
        refs.laptop?.style.setProperty("--sz-lap", "0px");
        refs.phone?.style.setProperty("--sz-ph", "0px");
      };
    },
  );
</script>
