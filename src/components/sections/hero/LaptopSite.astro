---
// Strona "drewelomet" renderowana na ekranie laptopa w Hero (showcase, wyłącznie
// wizualny). Przepisana z ref_sources/drewelomet-gsap-page/index.html:
//  • klasy z prefiksem dw- (brak kolizji z DeviceScene: .camera/.stage/.frame)
//  • position: fixed → absolute (uwięzienie w ekranie zamiast viewportu)
//  • vh/vw → cqh/cqw (jednostki względem ekranu = .dw-root z container-type: size)
//  • fonty przez tokeny --font-drewelomet-* (nasz mechanizm, nie Google Fonts)
//  • ścieżki obrazów → /drewelomet/* (public)
//  • scroll-containery usunięte — animacja napędzana master-timeline z Hero
//  • navbar uproszczony (statyczny kolor, bez stosu text-shadow / color-mix) — perf
// Logika (timeline'y, miarki, typewriter, galeria) żyje w laptop-site.ts.
---

<div class="dw-root" aria-hidden="true">
  <nav class="dw-nav">
    <div class="dw-brand">
      <svg class="dw-logo" viewBox="0 0 100 100" fill="none">
        <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="6"
        ></circle>
        <path d="M50 30 L71 67 L29 67 Z" fill="currentColor"></path>
      </svg>
      <span class="dw-name">drewelomet</span>
    </div>
    <div class="dw-nav-links">
      <span>OFERTA</span>
      <span>REALIZACJE</span>
      <span>O NAS</span>
      <span>KONTAKT</span>
    </div>
  </nav>

  <div class="dw-parallax">
    <div class="dw-camera-zoom">
      <div class="dw-camera">
        <div class="dw-layer dw-layer-bg">
          <img
            src="/drewelomet/background.webp"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="dw-layer dw-layer-shelf">
          <img
            src="/drewelomet/bookshelf.webp"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="dw-layer dw-layer-table">
          <img
            src="/drewelomet/table.webp"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="dw-layer dw-layer-text">
          <span class="dw-wood dw-mat dw-mat--wood" data-text="z drewna"
            >z drewna</span
          >
        </div>
        <div class="dw-layer dw-layer-steel">
          <span class="dw-steel dw-mat dw-mat--steel" data-text="i stali"
            >i stali</span
          >
        </div>
      </div>
    </div>
  </div>

  <div class="dw-stage">
    <div class="dw-bg-logo dw-bg-logo-left">
      <svg viewBox="0 0 100 100" fill="none">
        <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="6"
        ></circle>
        <path d="M50 30 L71 67 L29 67 Z" fill="currentColor"></path>
      </svg>
    </div>

    <div class="dw-frame">
      <div class="dw-object">
        <img
          class="dw-macro"
          src="/drewelomet/table_corner_macro_alt.webp"
          alt=""
          loading="lazy"
          decoding="async"
        />
        <img
          class="dw-proj1"
          src="/drewelomet/table_corner_project1_no_background.webp"
          alt=""
          loading="lazy"
          decoding="async"
        />
        <img
          class="dw-proj2"
          src="/drewelomet/table_corner_project2_no_background.webp"
          alt=""
          loading="lazy"
          decoding="async"
        />
        <img
          class="dw-proj3"
          src="/drewelomet/table_corner_project3_no_background.webp"
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

    <div class="dw-sec-text">
      <h2 class="dw-sec-heading">Od wizji do projektu</h2>
      <div class="dw-bullets-window">
        <ul class="dw-bullets">
          <li>Według twojego pomysłu.</li>
          <li>Dostosowane do Twojej przestrzeni.</li>
          <li>Współpraca z najlepszymi designerami.</li>
          <li>Setki przykładów.</li>
          <li>Szybki czas realizacji projektu.</li>
          <li>Wizualizacje od ręki.</li>
          <li>Najlepszy stosunek ceny do jakości.</li>
          <li>Precyzyjnie w każdym detalu.</li>
        </ul>
      </div>
    </div>

    <div class="dw-ruler dw-ruler-1"></div>
  </div>

  <section class="dw-section2">
    <div class="dw-bg-logo dw-bg-logo-right">
      <svg viewBox="0 0 100 100" fill="none">
        <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="6"
        ></circle>
        <path d="M50 30 L71 67 L29 67 Z" fill="currentColor"></path>
      </svg>
    </div>

    <div class="dw-s2-frame">
      <div class="dw-s2-scene">
        <div class="dw-s2-layer dw-s2-bg">
          <img
            src="/drewelomet/carpenter/carpenter_background1.webp"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="dw-s2-layer dw-s2-wood">
          <img
            src="/drewelomet/carpenter/carpenter_wood2.webp"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="dw-s2-layer dw-s2-man">
          <img
            src="/drewelomet/carpenter/carpenter_man3.webp"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="dw-s2-layer dw-s2-table">
          <img
            src="/drewelomet/carpenter/carpenter_table4.webp"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>

    <div class="dw-s2-text">
      <h2 class="dw-sec-heading">Warsztat</h2>
      <div class="dw-bullets-window">
        <ul class="dw-bullets dw-s2-bullets">
          <li>Najwyższa jakość materiałów.</li>
          <li>Stawiamy na pracę ludzkich rąk.</li>
          <li>Ręczna selekcja i obróbka.</li>
          <li>Certyfikowany kunszt.</li>
          <li>Sprawdzone technologie.</li>
          <li>Ponadczasowa ortodoksja jakości.</li>
          <li>Konstrukcje na pokolenia.</li>
          <li>Wieloletni, doświadczeni specjaliści.</li>
          <li>Wizjonerskie podejście do materii.</li>
          <li>Manifest współczesnego rzemiosła.</li>
          <li>Niezawodność.</li>
        </ul>
      </div>
    </div>

    <div class="dw-ruler dw-ruler-2"></div>
  </section>

  <section class="dw-section3">
    <div class="dw-g-item dw-g-hs">
      <img
        src="/drewelomet/products/high_shelf.webp"
        alt=""
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="dw-g-item dw-g-table">
      <img
        src="/drewelomet/products/table.webp"
        alt=""
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="dw-g-item dw-g-rtv">
      <img
        src="/drewelomet/products/rtv2.webp"
        alt=""
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="dw-g-item dw-g-coffee">
      <img
        src="/drewelomet/products/coffee_table1.webp"
        alt=""
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="dw-g-item dw-g-door">
      <img
        src="/drewelomet/products/door.webp"
        alt=""
        loading="lazy"
        decoding="async"
      />
    </div>

    <div class="dw-g-item dw-g-r2 dw-g-dog">
      <img
        src="/drewelomet/products/doghouse.webp"
        alt=""
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="dw-g-item dw-g-r2 dw-g-lamp">
      <img
        src="/drewelomet/products/lamp1.webp"
        alt=""
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="dw-g-item dw-g-r2 dw-g-book">
      <img
        src="/drewelomet/products/bookshelf.webp"
        alt=""
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="dw-g-item dw-g-r2 dw-g-bench">
      <img
        src="/drewelomet/products/bench.webp"
        alt=""
        loading="lazy"
        decoding="async"
      />
    </div>
  </section>
</div>

<style>
  /* ── Root = viewport drewelomet. container-type: size → cqw/cqh względem ekranu.
     .dw-root wypełnia .screen (absolute inset:0); .screen ma definitywny rozmiar
     (z --lap-w/--lap-h), więc container działa i jednostki cq są stabilne. ── */
  .dw-root {
    --bg: #c9c1b3;
    --ink: rgb(36, 23, 16);

    --wood-color: #3f352c;
    --wood-size: 10cqw;
    --wood-left: 14.5cqw;
    --wood-top: 11cqh;
    --wood-stroke-width: 0.95cqw;
    --wood-stroke-color: rgb(240, 232, 215);
    --wood-stroke2-width: 0.38cqw;
    --wood-stroke2-color: var(--wood-color);

    --steel-size: 5cqw;
    --steel-left: 58.5cqw;
    --steel-top: 30cqh;
    --steel-color: #bfbec4;
    --steel-stroke-width: 0.48cqw;
    --steel-stroke-color: #000000;
    --steel-stroke2-width: 0.19cqw;
    --steel-stroke2-color: #bfbec4;

    /* Nadpisywane z JS (laptop-site.ts → galleryLayout): realna wysokość navbara
       i wysokość kadru galerii. Deklaracja z fallbackiem = brak ostrzeżeń CSS. */
    --nav-h: 12cqh;
    --gh: 80cqh;

    position: absolute;
    inset: 0;
    overflow: hidden;
    background-color: var(--bg);
    container-type: size;
    contain: layout paint;
  }

  .dw-root * {
    box-sizing: border-box;
  }

  /* ── NAVBAR (uproszczony: statyczny kolor, jeden subtelny cień; bez stosu
     text-shadow i color-mix z oryginału — minimalny koszt GPU) ── */
  .dw-nav {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2.2cqh 4.8cqw;
    z-index: 100;
    color: #f4ead7;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
    will-change: color;
  }
  .dw-brand {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.8cqw;
  }
  .dw-logo {
    width: 4.2cqw;
    height: 4.2cqw;
    display: block;
  }
  .dw-name {
    font-family: var(--font-drewelomet-ui), serif;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 2.1cqw;
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .dw-nav-links {
    display: flex;
    gap: 4cqw;
    align-items: center;
  }
  .dw-nav-links span {
    font-family: var(--font-drewelomet-ui), serif;
    font-weight: 600;
    font-size: 1.9cqw;
    letter-spacing: 0.08em;
  }

  /* ── SCENA 1 — parallax pokoju ── */
  .dw-parallax {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 5;
    pointer-events: none;
    contain: layout paint;
    -webkit-mask-image: linear-gradient(
      to bottom,
      #000 0%,
      #000 99%,
      transparent 100%
    );
    mask-image: linear-gradient(to bottom, #000 0%, #000 99%, transparent 100%);
  }
  .dw-camera-zoom {
    position: absolute;
    inset: 0;
    transform-origin: center center;
    will-change: transform;
  }
  .dw-camera {
    position: absolute;
    inset: 0;
    will-change: transform;
  }

  .dw-layer {
    position: absolute;
    inset: 0;
  }
  .dw-layer img {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%) translateZ(0);
    display: block;
    backface-visibility: hidden;
  }
  .dw-layer-bg {
    z-index: 10;
    transform-origin: 80% 30%;
  }
  .dw-layer-shelf {
    z-index: 20;
    transform-origin: center 30%;
  }
  .dw-layer-table {
    z-index: 30;
    transform-origin: center 35%;
  }
  .dw-layer-text {
    z-index: 40;
    transform-origin: center 35%;
  }
  .dw-layer-steel {
    z-index: 50;
    transform-origin: 80% 30%;
  }

  .dw-wood {
    position: absolute;
    left: var(--wood-left);
    top: var(--wood-top);
    margin: 0;
    font-family: var(--font-drewelomet-wood), sans-serif;
    font-weight: 800;
    letter-spacing: -0.015em;
    word-spacing: 0.12em;
    line-height: 1;
    white-space: nowrap;
    text-transform: uppercase;
    color: var(--wood-color);
    font-size: var(--wood-size);
    -webkit-text-stroke: var(--wood-stroke-width) var(--wood-stroke-color);
    paint-order: stroke fill;
  }
  .dw-steel {
    position: absolute;
    left: var(--steel-left);
    top: var(--steel-top);
    margin: 0;
    font-family: var(--font-drewelomet-steel), sans-serif;
    font-weight: 700;
    letter-spacing: 0.03em;
    line-height: 1;
    white-space: nowrap;
    text-transform: uppercase;
    font-size: var(--steel-size);
    color: var(--steel-color);
    -webkit-text-fill-color: var(--steel-color);
    -webkit-text-stroke: var(--steel-stroke-width) var(--steel-stroke-color);
    paint-order: stroke fill;
  }
  .dw-steel::before {
    content: attr(data-text);
    position: absolute;
    left: 0;
    top: 0;
    z-index: -1;
    -webkit-text-stroke: calc(
        var(--steel-stroke-width) + var(--steel-stroke2-width)
      )
      var(--steel-stroke2-color);
    -webkit-text-fill-color: transparent;
    paint-order: stroke fill;
  }
  .dw-wood::before {
    content: attr(data-text);
    position: absolute;
    left: 0;
    top: 0;
    z-index: -1;
    -webkit-text-stroke: calc(
        var(--wood-stroke-width) + var(--wood-stroke2-width)
      )
      var(--wood-stroke2-color);
    -webkit-text-fill-color: transparent;
    paint-order: stroke fill;
  }
  .dw-mat {
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    -webkit-text-stroke: 0;
  }
  .dw-mat--wood {
    text-shadow:
      0 -1px 0 rgba(255, 236, 198, 0.5),
      0 1px 0 #3a2410,
      0 2px 0 #2a1a0a,
      0 4px 0 #1d1107,
      0 5px 6px rgba(0, 0, 0, 0.55);
    filter: drop-shadow(0 10px 13px rgba(0, 0, 0, 0.45));
  }
  .dw-mat--steel {
    text-shadow:
      0 -1px 0 rgba(255, 255, 255, 0.7),
      0 1px 0 #6c737a,
      0 2px 0 #474d52,
      0 3px 5px rgba(0, 0, 0, 0.5);
    filter: drop-shadow(0 7px 9px rgba(0, 0, 0, 0.45));
  }

  /* ── STAGE (scena 1: ramka + tekst + miarka) ── */
  .dw-stage {
    position: absolute;
    inset: 0;
    z-index: 70;
    pointer-events: none;
    contain: layout paint;
  }
  .dw-frame {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    contain: layout paint;
    --tb-feather: 0;
    -webkit-mask-image:
      linear-gradient(
        to right,
        transparent 0,
        #000 6%,
        #000 94%,
        transparent 100%
      ),
      linear-gradient(
        to bottom,
        transparent 0,
        #000 calc(var(--tb-feather) * 1%),
        #000 calc(100% - var(--tb-feather) * 1%),
        transparent 100%
      );
    -webkit-mask-composite: source-in;
    mask-image:
      linear-gradient(
        to right,
        transparent 0,
        #000 6%,
        #000 94%,
        transparent 100%
      ),
      linear-gradient(
        to bottom,
        transparent 0,
        #000 calc(var(--tb-feather) * 1%),
        #000 calc(100% - var(--tb-feather) * 1%),
        transparent 100%
      );
    mask-composite: intersect;
  }
  .dw-object {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 100cqw;
    height: 100cqh;
    transform-origin: center center;
  }
  .dw-object img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    display: block;
  }

  .dw-sec-text {
    position: absolute;
    left: 7cqw;
    top: 50%;
    width: 45cqw;
    opacity: 0;
    color: var(--ink);
    z-index: 10;
  }
  .dw-sec-heading {
    font-family: var(--font-drewelomet-display), sans-serif;
    font-weight: 700;
    font-size: 3.8cqw;
    line-height: 1.05;
    margin: 0 0 5cqh;
  }
  .dw-tw-cursor {
    display: none;
    width: 0.055em;
    height: 0.82em;
    margin-left: 0.06em;
    background: currentColor;
    vertical-align: -0.07em;
    border-radius: 1px;
  }
  .dw-tw-cursor.dw-tw-active {
    display: inline-block;
    animation: dw-tw-blink 0.9s steps(1, end) infinite;
  }
  @keyframes dw-tw-blink {
    0%,
    50% {
      opacity: 1;
    }
    50.01%,
    100% {
      opacity: 0;
    }
  }

  .dw-bullets-window {
    height: 33cqh;
    overflow: hidden;
  }
  .dw-bullets {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .dw-bullets li {
    height: 11cqh;
    display: flex;
    align-items: center;
    font-family: var(--font-drewelomet-display), sans-serif;
    font-weight: 600;
    font-size: 1.9cqw;
    letter-spacing: 0.01em;
    color: #241c15;
  }
  .dw-bullets li::before {
    content: "–";
    margin-right: 0.6em;
    color: #3f352c;
  }

  /* ── SEKCJA 2 ── */
  .dw-section2 {
    position: absolute;
    inset: 0;
    z-index: 75;
    background: var(--bg);
    color: var(--ink);
    pointer-events: none;
    contain: layout paint;
  }
  .dw-s2-frame {
    position: absolute;
    left: -3cqw;
    top: calc(50% - 30cqh);
    width: 46cqw;
    height: 64cqh;
    transform-origin: right top;
    overflow: hidden;
    contain: layout paint;
  }
  .dw-s2-scene {
    position: absolute;
    inset: 0;
  }
  .dw-s2-layer {
    position: absolute;
    inset: 0;
    transform-origin: 50% 62%;
  }
  .dw-s2-layer img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    backface-visibility: hidden;
  }
  .dw-s2-bg {
    z-index: 10;
  }
  .dw-s2-wood {
    z-index: 20;
  }
  .dw-s2-man {
    z-index: 30;
  }
  .dw-s2-table {
    z-index: 40;
  }
  .dw-s2-text {
    position: absolute;
    right: 7cqw;
    top: calc(50% - 26cqh);
    width: 40cqw;
    color: var(--ink);
    z-index: 10;
  }
  .dw-s2-text .dw-bullets-window {
    height: 54cqh;
  }

  /* ── SEKCJA 3 — GALERIA ── */
  .dw-section3 {
    position: absolute;
    inset: 0;
    z-index: 80;
    background: var(--bg);
    overflow: hidden;
    pointer-events: none;
    contain: layout paint;
  }
  .dw-g-item {
    position: absolute;
    top: var(--nav-h, 12cqh);
    height: var(--gh, 80cqh);
  }
  .dw-g-item img {
    display: block;
    height: 100%;
    width: auto;
    backface-visibility: hidden;
  }
  .dw-g-table,
  .dw-g-rtv,
  .dw-g-coffee,
  .dw-g-door {
    z-index: 3;
  }
  .dw-g-hs {
    z-index: 2;
  }
  .dw-g-r2 {
    z-index: 3;
    opacity: 0;
  }

  /* ── Miarka krawiecka ── */
  .dw-ruler {
    position: absolute;
    top: 8cqh;
    height: 84cqh;
    width: 7cqw;
    pointer-events: none;
    z-index: 60;
    --draw: 0;
    --ruler-color: rgba(36, 23, 16, 0.72);
    --tick-min: 1.4cqw;
    --tick-mid: 3cqw;
    --tick-max: 4.6cqw;
  }
  .dw-ruler-line {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--ruler-color);
  }
  .dw-ruler-tick {
    position: absolute;
    height: 1.5px;
    background: var(--ruler-color);
  }
  .dw-ruler-1 {
    left: 2cqw;
    -webkit-mask-image: linear-gradient(
      to top,
      #000 calc(var(--draw) * 100%),
      transparent calc(var(--draw) * 100%)
    );
    mask-image: linear-gradient(
      to top,
      #000 calc(var(--draw) * 100%),
      transparent calc(var(--draw) * 100%)
    );
  }
  .dw-ruler-1 .dw-ruler-line {
    left: 0;
  }
  .dw-ruler-1 .dw-ruler-tick {
    left: 0;
  }
  .dw-ruler-2 {
    right: 2cqw;
    -webkit-mask-image: linear-gradient(
      to bottom,
      #000 calc(var(--draw) * 100%),
      transparent calc(var(--draw) * 100%)
    );
