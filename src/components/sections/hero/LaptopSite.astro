---
// Strona "drewelomet" renderowana na ekranie laptopa w Hero (showcase, wyłącznie
// wizualny). Przepisana z ref_sources/drewelomet-gsap-page/index.html:
//  • klasy z prefiksem dw- (brak kolizji z DeviceScene: .camera/.stage/.frame)
//  • position: fixed → absolute (uwięzienie w ekranie zamiast viewportu)
//  • vh/vw → cqh/cqw (jednostki względem ekranu = .dw-root z container-type: size)
//  • fonty przez tokeny --font-drewelomet-* (nasz mechanizm, nie Google Fonts)
//  • ścieżki obrazów → /drewelomet/* (public)
//  • scroll-containery usunięte — animacja napędzana master-timeline z Hero
//  • navbar uproszczony (statyczny kolor, bez stosu text-shadow / color-mix) — perf
// Logika (timeline'y, miarki, typewriter, galeria) żyje w laptop-site.ts.
---

<div class="dw-root" aria-hidden="true">
  <div class="dw-chrome">
    <div class="dw-chrome-dots">
      <span class="dw-dot dw-dot--close"></span>
      <span class="dw-dot dw-dot--min"></span>
      <span class="dw-dot dw-dot--max"></span>
    </div>
    <div class="dw-chrome-url">drewelomet.pl</div>
  </div>

  <div class="dw-page">
    <nav class="dw-nav">
      <div class="dw-brand">
        <svg class="dw-logo" viewBox="0 0 100 100" fill="none">
          <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="6"
          ></circle>
          <path d="M50 30 L71 67 L29 67 Z" fill="#D8B468"></path>
        </svg>
        <span class="dw-name">drewelomet</span>
      </div>
      <div class="dw-nav-links">
        <span>OFERTA</span>
        <span>REALIZACJE</span>
        <span>O NAS</span>
        <span>KONTAKT</span>
      </div>
    </nav>

    <div class="dw-parallax">
      <div class="dw-camera-zoom">
        <div class="dw-camera">
          <div class="dw-layer dw-layer-bg">
            <img
              src="/drewelomet/background.webp"
              alt=""
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="dw-layer dw-layer-shelf">
            <img
              src="/drewelomet/bookshelf.webp"
              alt=""
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="dw-layer dw-layer-table">
            <img
              src="/drewelomet/table.webp"
              alt=""
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="dw-loft-tint"></div>
          <div class="dw-layer dw-layer-text">
            <span class="dw-wood dw-mat dw-mat--wood" data-text="z drewna"
              >z drewna</span
            >
          </div>
          <div class="dw-layer dw-layer-steel">
            <span class="dw-steel dw-mat dw-mat--steel" data-text="i stali"
              >i stali</span
            >
          </div>
        </div>
      </div>
    </div>

    <div class="dw-stage">
      <div class="dw-bg-logo dw-bg-logo-left">
        <svg viewBox="0 0 100 100" fill="none">
          <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="6"
          ></circle>
          <path d="M50 30 L71 67 L29 67 Z" fill="currentColor"></path>
        </svg>
      </div>

      <div class="dw-frame">
        <div class="dw-object">
          <img
            class="dw-macro"
            src="/drewelomet/table_corner_macro_alt.webp"
            alt=""
            loading="lazy"
            decoding="async"
          />
          <img
            class="dw-proj1"
            src="/drewelomet/table_corner_project1_no_background.webp"
            alt=""
            loading="lazy"
            decoding="async"
          />
          <img
            class="dw-proj2"
            src="/drewelomet/table_corner_project2_no_background.webp"
            alt=""
            loading="lazy"
            decoding="async"
          />
          <img
            class="dw-proj3"
            src="/drewelomet/table_corner_project3_no_background.webp"
            alt=""
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>

      <div class="dw-sec-text">
        <!-- Twarde spacje wiążą „Od wizji" i „do projektu" w nierozłączne grupy;
             jedyna łamliwa spacja jest między nimi → przy zawinięciu zawsze wypada
             podział „Od wizji" / „do projektu". (Typewriter odtwarza textContent jako
             czysty tekst, więc <br> by nie zadziałał — nbsp przetrwa.) -->
        <h2 class="dw-sec-heading">Od&nbsp;wizji do&nbsp;projektu</h2>
        <div class="dw-bullets-window">
          <ul class="dw-bullets">
            <li>Według twojego pomysłu.</li>
            <li>Dostosowane do Twojej przestrzeni.</li>
            <li>Współpraca z najlepszymi designerami.</li>
            <li>Setki przykładów.</li>
            <li>Szybki czas realizacji projektu.</li>
            <li>Wizualizacje od ręki.</li>
            <li>Najlepszy stosunek ceny do jakości.</li>
            <li>Precyzyjnie w każdym detalu.</li>
          </ul>
        </div>
      </div>

      <div class="dw-ruler dw-ruler-1"></div>
    </div>

    <section class="dw-section2">
      <div class="dw-bg-logo dw-bg-logo-right">
        <svg viewBox="0 0 100 100" fill="none">
          <circle cx="50" cy="50" r="45" stroke="currentColor" stroke-width="6"
          ></circle>
          <path d="M50 30 L71 67 L29 67 Z" fill="currentColor"></path>
        </svg>
      </div>

      <div class="dw-s2-frame">
        <div class="dw-s2-scene">
          <div class="dw-s2-layer dw-s2-bg">
            <img
              src="/drewelomet/carpenter/carpenter_background1.webp"
              alt=""
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="dw-s2-layer dw-s2-wood">
            <img
              src="/drewelomet/carpenter/carpenter_wood2.webp"
              alt=""
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="dw-s2-layer dw-s2-man">
            <img
              src="/drewelomet/carpenter/carpenter_man3.webp"
              alt=""
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="dw-s2-layer dw-s2-table">
            <img
              src="/drewelomet/carpenter/carpenter_table4.webp"
              alt=""
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>

      <div class="dw-s2-text">
        <h2 class="dw-sec-heading">Warsztat</h2>
        <div class="dw-bullets-window">
          <ul class="dw-bullets dw-s2-bullets">
            <li>Najwyższa jakość materiałów.</li>
            <li>Stawiamy na pracę ludzkich rąk.</li>
            <li>Ręczna selekcja i obróbka.</li>
            <li>Certyfikowany kunszt.</li>
            <li>Sprawdzone technologie.</li>
            <li>Ponadczasowa ortodoksja jakości.</li>
            <li>Konstrukcje na pokolenia.</li>
            <li>Wieloletni, doświadczeni specjaliści.</li>
            <li>Wizjonerskie podejście do materii.</li>
            <li>Manifest współczesnego rzemiosła.</li>
            <li>Niezawodność.</li>
          </ul>
        </div>
      </div>

      <div class="dw-ruler dw-ruler-2"></div>
    </section>

    <section class="dw-section3">
      <div class="dw-g-item dw-g-hs">
        <img
          src="/drewelomet/products/high_shelf.webp"
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="dw-g-item dw-g-table">
        <img
          src="/drewelomet/products/table.webp"
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="dw-g-item dw-g-rtv">
        <img
          src="/drewelomet/products/rtv2.webp"
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="dw-g-item dw-g-coffee">
        <img
          src="/drewelomet/products/coffee_table1.webp"
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="dw-g-item dw-g-door">
        <img
          src="/drewelomet/products/door.webp"
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>

      <div class="dw-g-item dw-g-r2 dw-g-dog">
        <img
          src="/drewelomet/products/doghouse.webp"
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="dw-g-item dw-g-r2 dw-g-lamp">
        <img
          src="/drewelomet/products/lamp1.webp"
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="dw-g-item dw-g-r2 dw-g-book">
        <img
          src="/drewelomet/products/bookshelf.webp"
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="dw-g-item dw-g-r2 dw-g-bench">
        <img
          src="/drewelomet/products/bench.webp"
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
    </section>
  </div>
</div>

<style>
  /* ── Root = viewport drewelomet. container-type: size → cqw/cqh względem ekranu.
     .dw-root wypełnia .screen (absolute inset:0); .screen ma definitywny rozmiar
     (z --lap-w/--lap-h), więc container działa i jednostki cq są stabilne. ── */
  .dw-root {
    --bg: #c9c1b3;
    --ink: rgb(36, 23, 16);
    /* Wysokość paska Chrome ≈ 34px @ ekranie 534px. O tę wartość .dw-page jest
       przepchnięta w dół (czysty translateY, dół ekranu przycięty). */
    --chrome-h: 6.4cqh;

    --wood-color: #3f352c;
    --wood-size: 10cqw;
    --wood-left: 14.5cqw;
    --wood-top: 11cqh;
    --wood-stroke-width: 0.95cqw;
    --wood-stroke-color: rgb(240, 232, 215);
    --wood-stroke2-width: 0.38cqw;
    --wood-stroke2-color: var(--wood-color);

    --steel-size: 5cqw;
    --steel-left: 58.5cqw;
    --steel-top: 30cqh;
    --steel-color: #bfbec4;
    --steel-stroke-width: 0.48cqw;
    --steel-stroke-color: #000000;
    --steel-stroke2-width: 0.19cqw;
    --steel-stroke2-color: #bfbec4;

    /* Nadpisywane z JS (laptop-site.ts → galleryLayout): realna wysokość navbara
       i wysokość kadru galerii. Deklaracja z fallbackiem = brak ostrzeżeń CSS. */
    --nav-h: 12cqh;
    --gh: 80cqh;

    position: absolute;
    inset: 0;
    overflow: hidden;
    background-color: var(--bg);
    container-type: size;
    contain: layout paint;
  }

  .dw-root * {
    box-sizing: border-box;
  }

  /* ── CHROM PRZEGLĄDARKI (pasek macOS/Chrome) — stały przez całą animację,
     ponad przepychaną stroną, przyklejony do górnej krawędzi ekranu. ── */
  .dw-chrome {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--chrome-h);
    z-index: 200;
    display: flex;
    align-items: center;
    gap: 1.8cqw;
    padding: 0 2.2cqw;
    background: #15110f;
    color: #9a9088;
    font-family: var(--font-drewelomet-mono), ui-monospace, monospace;
  }
  .dw-chrome-dots {
    display: flex;
    align-items: center;
    gap: 1cqw;
    flex: none;
  }
  .dw-dot {
    width: 2.05cqh;
    height: 2.05cqh;
    border-radius: 50%;
  }
  .dw-dot--close {
    background: #ec6a5e;
  }
  .dw-dot--min {
    background: #f4bf4f;
  }
  .dw-dot--max {
    background: #61c554;
  }
  .dw-chrome-url {
    flex: 1 1 auto;
    min-width: 0;
    height: 64%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 2.4cqw;
    border-radius: 99px;
    background: #241d1a;
    color: #b3a89e;
    font-size: 1.45cqw;
    letter-spacing: 0.02em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Strona drewelomet: cała treść przepchnięta pod chrom o --chrome-h.
     Czysty translateY — container-type został na .dw-root, więc jednostki cq
     się nie zmieniają i timeline jest spasowany 1:1 jak dotąd. ── */
  .dw-page {
    position: absolute;
    inset: 0;
    transform: translateY(var(--chrome-h));
  }

  /* ── NAVBAR (uproszczony: statyczny kolor, jeden subtelny cień; bez stosu
     text-shadow i color-mix z oryginału — minimalny koszt GPU) ── */
  .dw-nav {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2.2cqh 4.8cqw;
    z-index: 100;
    color: #f4ead7;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
  }
  .dw-brand {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.8cqw;
  }
  .dw-logo {
    width: 4.2cqw;
    height: 4.2cqw;
    display: block;
  }
  .dw-name {
    font-family: var(--font-display), system-ui, sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 2.1cqw;
    letter-spacing: 0.05em;
    line-height: 1;
    color: #f4ead7;
  }
  /* Linki w „pigułce" — statyczne półprzezroczyste tło (bez backdrop-filter:
     pewność wydajności wewnątrz transformowanego 3D laptopa). */
  .dw-nav-links {
    display: flex;
    gap: 2.2cqw;
    align-items: center;
    padding: 1cqh 2cqw;
    border-radius: 99px;
    background: rgba(20, 14, 9, 0.34);
    border: 1px solid rgba(244, 234, 215, 0.16);
  }
  .dw-nav-links span {
    font-family: var(--font-display), system-ui, sans-serif;
    font-weight: 600;
    font-size: 1.6cqw;
    letter-spacing: 0.14em;
    color: #f4ead7;
  }

  /* ── SCENA 1 — parallax pokoju ── */
  .dw-parallax {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 5;
    pointer-events: none;
    contain: layout paint;
    -webkit-mask-image: linear-gradient(
      to bottom,
      #000 0%,
      #000 99%,
      transparent 100%
    );
    mask-image: linear-gradient(to bottom, #000 0%, #000 99%, transparent 100%);
  }
  /* will-change tylko gdy faza 3 aktywna (.is-active) — patrz blok niżej.
     Stałe promowanie tych warstw to niepotrzebny koszt VRAM poza animacją.
     W trakcie sceny 1 JS i tak ustawia will-change inline na .dw-camera-zoom. */
  .dw-camera-zoom {
    position: absolute;
    inset: 0;
    transform-origin: center center;
  }
  .dw-camera {
    position: absolute;
    inset: 0;
  }

  .dw-layer {
    position: absolute;
    inset: 0;
  }
  .dw-layer img {
    position: absolute;
    top: 50%;
    left: 50%;
    min-width: 100%;
    min-height: 100%;
    width: auto;
    height: auto;
    transform: translate(-50%, -50%) translateZ(0);
    display: block;
    backface-visibility: hidden;
  }
  .dw-layer-bg {
    z-index: 10;
    transform-origin: 80% 30%;
  }
  /* Nakładka koloru na scenę loftu: warstwa między stołem (z30) a napisami (z40),
     więc mnożenie #6b3a12 obejmuje tło + regał + stół, a napisy „z drewna"/„i stali"
     zostają nad nią (czyste). Nie podmienia obrazów — tylko je tonuje. */
  .dw-loft-tint {
    position: absolute;
    inset: 0;
    z-index: 35;
    background: #6b3a12;
    opacity: 0.2;
    mix-blend-mode: multiply;
    pointer-events: none;
  }
  .dw-layer-shelf {
    z-index: 20;
    transform-origin: center 30%;
  }
  .dw-layer-table {
    z-index: 30;
    transform-origin: center 35%;
  }
  .dw-layer-text {
    z-index: 40;
    transform-origin: center 35%;
  }
  .dw-layer-steel {
    z-index: 50;
    transform-origin: 80% 30%;
  }

  .dw-wood {
    position: absolute;
    left: var(--wood-left);
    top: var(--wood-top);
    margin: 0;
    font-family: var(--font-drewelomet-wood), sans-serif;
    font-weight: 800;
    letter-spacing: -0.015em;
    word-spacing: 0.12em;
    line-height: 1;
    white-space: nowrap;
    text-transform: uppercase;
    color: var(--wood-color);
    font-size: var(--wood-size);
    -webkit-text-stroke: var(--wood-stroke-width) var(--wood-stroke-color);
    paint-order: stroke fill;
  }
  .dw-steel {
    position: absolute;
    left: var(--steel-left);
    top: var(--steel-top);
    margin: 0;
    font-family: var(--font-drewelomet-steel), sans-serif;
    font-weight: 700;
    letter-spacing: 0.03em;
    line-height: 1;
    white-space: nowrap;
    text-transform: uppercase;
    font-size: var(--steel-size);
    color: var(--steel-color);
    -webkit-text-fill-color: var(--steel-color);
    -webkit-text-stroke: var(--steel-stroke-width) var(--steel-stroke-color);
    paint-order: stroke fill;
  }
  .dw-steel::before {
    content: attr(data-text);
    position: absolute;
    left: 0;
    top: 0;
    z-index: -1;
    -webkit-text-stroke: calc(
        var(--steel-stroke-width) + var(--steel-stroke2-width)
      )
      var(--steel-stroke2-color);
    -webkit-text-fill-color: transparent;
    paint-order: stroke fill;
  }
  .dw-wood::before {
    content: attr(data-text);
    position: absolute;
    left: 0;
    top: 0;
    z-index: -1;
    -webkit-text-stroke: calc(
        var(--wood-stroke-width) + var(--wood-stroke2-width)
      )
      var(--wood-stroke2-color);
    -webkit-text-fill-color: transparent;
    paint-order: stroke fill;
  }
  .dw-mat {
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    -webkit-text-stroke: 0;
  }
  .dw-mat--wood {
    text-shadow:
      0 -1px 0 rgba(255, 236, 198, 0.5),
      0 1px 0 #3a2410,
      0 2px 0 #2a1a0a,
      0 4px 0 #1d1107,
      0 5px 6px rgba(0, 0, 0, 0.55);
    filter: drop-shadow(0 10px 13px rgba(0, 0, 0, 0.45));
  }
  .dw-mat--steel {
    text-shadow:
      0 -1px 0 rgba(255, 255, 255, 0.7),
      0 1px 0 #6c737a,
      0 2px 0 #474d52,
      0 3px 5px rgba(0, 0, 0, 0.5);
    filter: drop-shadow(0 7px 9px rgba(0, 0, 0, 0.45));
  }

  /* ── STAGE (scena 1: ramka + tekst + miarka) ── */
  .dw-stage {
    position: absolute;
    inset: 0;
    z-index: 70;
    pointer-events: none;
    contain: layout paint;
  }
  .dw-frame {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    contain: layout paint;
    /* Obrazek nad logiem w tle (.dw-bg-logo z-index:1), pod tekstem (10) i miarką (60). */
    z-index: 5;
    /* Wszystkie krawędzie sterowane jednym featherem (0 = twarde). To stan
       początkowy/fallback (macro = twarde krawędzie); właściwą animację 0→6
       w oknie crossfade macro→proj1 wpisuje inline JS (laptop-site.ts), bo zmiana
       zmiennej w masce nie repaintuje pewnie w transformacie 3D laptopa. */
    --frame-feather: 0;
    -webkit-mask-image:
      linear-gradient(
        to right,
        transparent 0,
        #000 calc(var(--frame-feather) * 1%),
        #000 calc(100% - var(--frame-feather) * 1%),
        transparent 100%
      ),
      linear-gradient(
        to bottom,
        transparent 0,
        #000 calc(var(--frame-feather) * 1%),
        #000 calc(100% - var(--frame-feather) * 1%),
        transparent 100%
      );
    -webkit-mask-composite: source-in;
    mask-image:
      linear-gradient(
        to right,
        transparent 0,
        #000 calc(var(--frame-feather) * 1%),
        #000 calc(100% - var(--frame-feather) * 1%),
        transparent 100%
      ),
      linear-gradient(
        to bottom,
        transparent 0,
        #000 calc(var(--frame-feather) * 1%),
        #000 calc(100% - var(--frame-feather) * 1%),
        transparent 100%
      );
    mask-composite: intersect;
  }
  .dw-object {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 100cqw;
    height: 100cqh;
    transform-origin: center center;
  }
  .dw-object img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    display: block;
  }

  /* Lewa kolumna tekstu, kotwiczona DOŁEM (nie wyśrodkowana): gdy nagłówek
     zawinie się do dwóch linii, blok rozpycha się w górę, a scrollowane bullety
     zostają w tym samym miejscu. Szerokość okna bulletów nadpisana niżej. */
  .dw-sec-text {
    position: absolute;
    left: 10cqw;
    bottom: 20cqh;
    width: 30cqw;
    opacity: 0;
    color: var(--ink);
    z-index: 10;
  }
  .dw-sec-heading {
    font-family: var(--font-drewelomet-heading), sans-serif;
    font-weight: 600;
    text-transform: uppercase;
