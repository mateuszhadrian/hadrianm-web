---
// Tło sekcji „Oferta" (services). Animowany glow z tokenów --sec-services-*
// (global.css), które mają fallback sRGB dla przeglądarek bez oklch().
---

<div class="services-bg" aria-hidden="true">
  <span class="services-bg__glow"></span>
</div>

<style>
  .services-bg {
    position: absolute;
    inset: 0;
    background: #000;
    overflow: clip;
    isolation: isolate;
  }

  .services-bg__glow {
    position: absolute;
    inset: -20%;
    filter: blur(55px);
    will-change: transform;
    background:
      radial-gradient(
        50% 50% at 30% 35%,
        var(--sec-services-1),
        transparent 70%
      ),
      radial-gradient(
        45% 45% at 75% 70%,
        var(--sec-services-2),
        transparent 72%
      );
    animation: services-drift 9s ease-in-out infinite alternate;
  }

  @keyframes services-drift {
    from {
      transform: translate3d(-3%, -2%, 0) scale(1.05);
    }
    to {
      transform: translate3d(4%, 3%, 0) scale(1.18);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .services-bg__glow {
      animation: none;
    }
  }

  /* gdy warstwa jest niewidoczna: pauza animacji + zwolnienie warstwy GPU */
  :global(.bg-layer.is-inactive) .services-bg__glow {
    animation-play-state: paused;
    will-change: auto;
  }
</style>
