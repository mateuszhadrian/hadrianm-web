---
import "@fontsource-variable/archivo/index.css";
import "@fontsource/instrument-serif/400.css";
import "@fontsource/instrument-serif/400-italic.css";

// Fonty strony drewelomet (ekran laptopa w Hero). Pliki woff2 ściągają się
// dopiero gdy realnie użyte — LaptopSite renderuje się tylko na desktop/tablet,
// więc na mobile dochodzą tu jedynie reguły @font-face (bez pobrań).
import "@fontsource/chakra-petch/latin-600.css";
import "@fontsource/chakra-petch/latin-700.css";
import "@fontsource/chakra-petch/latin-ext-600.css";
import "@fontsource/chakra-petch/latin-ext-700.css";
import "@fontsource/raleway/latin-800.css";
import "@fontsource/raleway/latin-ext-800.css";
import "@fontsource/stardos-stencil/latin-700.css";
import "@fontsource/zilla-slab/latin-600.css";
import "@fontsource/zilla-slab/latin-700.css";

import "@/styles/global.css";

interface Props {
  title?: string;
  lang?: string;
}
const { title = "hadrianm — web", lang = "pl" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
